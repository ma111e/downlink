{{define "title"}}Runs · LLM Monitor{{end}}
{{define "crumb"}}digest generation runs{{end}}
{{define "content"}}
  <div class="panel">
    <div class="stat-row" style="margin-bottom:18px">
      <div class="stat"><div class="n">{{len .Runs}}</div><div class="l">runs</div></div>
      <div class="stat"><div class="n">{{comma .Chart.MaxTokens}}</div><div class="l">peak tokens / run</div></div>
    </div>
    {{if .Chart.HasData}}
    <svg class="chart" width="100%" viewBox="0 0 {{.Chart.Width}} {{.Chart.Height}}" preserveAspectRatio="xMinYMax meet">
      {{range .Chart.Bars}}
      <rect x="{{.X}}" y="{{.Y}}" width="{{.W}}" height="{{.H}}" rx="2" fill="var(--bar)">
        <title>{{.When}} — {{comma .Tokens}} tokens</title>
      </rect>
      {{end}}
    </svg>
    <div class="muted" style="font-size:11px;margin-top:6px">total tokens per run · oldest → newest</div>
    {{else}}
    <div class="muted" style="font-size:12px">No token data yet — run a digest generation.</div>
    {{end}}
  </div>

  <div class="panel" style="padding:0">
    <table>
      <thead>
        <tr>
          <th>Started</th>
          <th>Run</th>
          <th>Digest</th>
          <th class="num">Calls</th>
          <th class="num">Tokens</th>
        </tr>
      </thead>
      <tbody>
        {{range .Runs}}
        <tr>
          <td class="muted">{{shortTime .StartedAt}}</td>
          <td><a class="mono" href="/run/{{.Id}}">{{.Id}}</a>{{if .Title}}<div class="muted" style="font-size:12px">{{truncate 70 .Title}}</div>{{end}}</td>
          <td class="mono muted">{{if .DigestId}}{{.DigestId}}{{else}}—{{end}}</td>
          <td class="num">{{.CallCount}}</td>
          <td class="num">{{comma .TotalTokens}}</td>
        </tr>
        {{else}}
        <tr><td colspan="5" class="empty">No runs recorded yet.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
{{end}}
