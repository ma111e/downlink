<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{block "title" .}}LLM Monitor{{end}} · downlink</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#fafaf9; --card:#ffffff; --dark:#1c1917;
    --ink:#0c0a09; --slate:#78716c; --soft:#a8a29e; --mist:#afafae;
    --border:#e5e7eb; --border-warm:#d6d3d1; --border-fog:#e1dfdd;
    --signal:#3ba6f1; --wash:#c1e1f7;
    --font-sans:"Inter",system-ui,-apple-system,sans-serif;
    --font-display:"Geist","Inter",system-ui,sans-serif;
    --font-mono:ui-monospace,SFMono-Regular,Menlo,monospace;
    --shadow:rgba(0,0,0,0.05) 0 4px 16px;
    --shadow-nav:rgba(0,0,0,0.05) 0 1px 2px;
  }
  * { box-sizing: border-box; }
  html { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  body {
    margin: 0; background: var(--bg); color: var(--ink);
    font-family: var(--font-sans); font-size: 14px; line-height: 1.5;
    font-feature-settings: "cv11","ss01";
  }
  a { color: inherit; text-decoration: none; }
  ::selection { background: var(--wash); color: var(--ink); }

  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px 96px; }

  /* top bar */
  header.top {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 90px; margin: 0 -24px 28px;
    border-bottom: 1px solid var(--border-fog);
    background: var(--bg); box-shadow: var(--shadow-nav);
    position: sticky; top: 0; z-index: 10;
  }
  header.top .mark {
    font-family: var(--font-display); font-weight: 500; font-size: 16px; letter-spacing: -.01em;
    color: var(--ink); display: inline-flex; align-items: center; gap: 9px;
  }
  header.top .mark b { font-weight: 500; }
  header.top .mark .sub { color: var(--soft); font-weight: 400; }
  header.top .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--signal); flex: none; }
  header.top .nav { display: flex; gap: 4px; margin-left: 10px; }
  header.top .nav a {
    font-size: 14px; font-weight: 500; color: var(--slate);
    padding: 6px 12px; border-radius: 9999px;
  }
  header.top .nav a:hover { color: var(--ink); background: #f2f1ef; }
  header.top .crumb { margin-left: auto; font-size: 13px; color: var(--slate); }
  header.top .crumb a { color: var(--signal); }
  header.top .crumb a:hover { text-decoration: underline; }

  /* panels / cards */
  .panel {
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    box-shadow: var(--shadow);
  }
  .panel.pad { padding: 24px; }
  .panel + .panel, .stats + .panel, .panel + .stats { margin-top: 20px; }
  .section-label {
    font-size: 12px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase;
    color: var(--slate); margin: 0 0 14px;
  }

  /* stat strip */
  .stats { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 20px; }
  .stat {
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    box-shadow: var(--shadow); padding: 18px 18px 16px; position: relative; overflow: hidden;
  }
  .stat::before { content:""; position:absolute; left:0; top:0; bottom:0; width:3px; background: var(--border-warm); }
  .stat.up::before   { background: var(--signal); }
  .stat.down::before { background: var(--wash); }
  .stat .l { font-size: 12px; font-weight: 500; color: var(--slate); }
  .stat .n {
    font-family: var(--font-display); font-size: 26px; font-weight: 400; letter-spacing: -.01em;
    font-variant-numeric: tabular-nums; color: var(--ink); margin-top: 8px;
  }
  .stat .sub { font-size: 12px; color: var(--soft); margin-top: 3px; }

  /* table */
  table { width: 100%; border-collapse: collapse; }
  thead th {
    font-size: 12px; font-weight: 500; letter-spacing: .03em; text-transform: uppercase;
    color: var(--slate); text-align: left; padding: 13px 16px; border-bottom: 1px solid var(--border);
  }
  tbody td { padding: 13px 16px; border-bottom: 1px solid var(--border-fog); vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr { transition: background .12s; position: relative; cursor: pointer; }
  tbody tr:hover { background: #faf9f8; }
  /* whole-row link: the .runid anchor is stretched to cover the row (no JS) */
  .runid::after { content: ""; position: absolute; inset: 0; }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.up   { color: var(--signal); }
  td.down { color: var(--slate); }
  .mono { font-family: var(--font-mono); }
  .muted { color: var(--slate); }
  .faint { color: var(--soft); }
  .runid { font-family: var(--font-mono); font-size: 13px; color: var(--ink); }
  tbody tr:hover .runid { color: var(--signal); }
  .subtitle { font-size: 12px; color: var(--slate); margin-top: 3px; }
  .empty { text-align: center; color: var(--slate); padding: 48px 0; font-size: 14px; }

  /* ratio mini-bar (table) */
  .ratio { display: flex; height: 5px; width: 92px; border-radius: 9999px; overflow: hidden; background: #eef0ee; }
  .ratio i { display: block; height: 100%; }
  .ratio .u { background: var(--signal); }
  .ratio .d { background: var(--wash); }

  /* chart */
  .chart-head { display: flex; align-items: baseline; gap: 18px; margin-bottom: 18px; }
  .legend { margin-left: auto; display: flex; gap: 16px; font-size: 12px; color: var(--slate); }
  .legend span { display: inline-flex; align-items: center; gap: 7px; }
  .legend i { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }
  .legend .u { background: var(--signal); }
  .legend .d { background: var(--wash); }
  .chart-wrap { position: relative; }
  .charttip {
    position: absolute; pointer-events: none; opacity: 0; transition: opacity .12s;
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    padding: 10px 12px; font-size: 12px; line-height: 1.6;
    color: var(--ink); white-space: nowrap; z-index: 6;
    box-shadow: var(--shadow); font-variant-numeric: tabular-nums;
  }
  .charttip b { font-weight: 600; }
  .charttip span { display: block; color: var(--soft); font-size: 11px; margin: 2px 0 6px; }
  .charttip i { display: block; font-style: normal; color: var(--slate); }
  .charttip i.s { color: var(--signal); }
  .charttip i.r { color: var(--slate); }
  svg.chart { display: block; width: 100%; height: 150px; overflow: visible; }
  svg.chart .hit { fill: transparent; }
  svg.chart g.barcol { cursor: default; }
  svg.chart .gl { stroke: var(--border-fog); stroke-width: 1; }
  svg.chart .ax { fill: var(--soft); font-family: var(--font-sans); font-size: 10px; }
  svg.chart .bar-up   { fill: var(--signal); }
  svg.chart .bar-down { fill: var(--wash); }
  .chart-caption { font-size: 12px; color: var(--soft); margin-top: 12px; }

  /* conversation cards */
  details.call { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 12px; overflow: hidden; background: var(--card); }
  details.call > summary { cursor: pointer; list-style: none; padding: 14px 16px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  details.call > summary::-webkit-details-marker { display: none; }
  details.call > summary::before { content: "▸"; color: var(--soft); font-size: 11px; transition: transform .15s; }
  details.call[open] > summary::before { transform: rotate(90deg); }
  details.call[open] > summary { border-bottom: 1px solid var(--border); background: #faf9f8; }
  .call .label { font-family: var(--font-mono); font-size: 12px; color: var(--ink); }
  .call .model { font-size: 13px; color: var(--slate); }
  .call .spacer { flex: 1; }
  .chip { font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: 9999px; border: 1px solid var(--border); display: inline-flex; align-items: center; gap: 5px; color: var(--slate); }
  .chip.u { color: var(--signal); background: #f2f9fe; border-color: #cfe7fa; }
  .chip.d { color: var(--slate); border-color: var(--border); }
  .chip.err { color: var(--ink); border-color: var(--border-warm); }
  .chip.na { color: var(--soft); }
  .call .body { padding: 6px 16px 18px; }
  .call h4 { margin: 16px 0 7px; font-size: 12px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase; color: var(--slate); }
  pre.text { white-space: pre-wrap; word-break: break-word; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 13px 15px; margin: 0; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.6; max-height: 480px; overflow: auto; color: var(--ink); }
  pre.text.err { color: var(--ink); border-color: var(--border-warm); }

  /* gentle page-load reveal */
  .reveal { opacity: 0; transform: translateY(8px); animation: revealIn .5s cubic-bezier(.2,.7,.3,1) forwards; }
  @keyframes revealIn { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 760px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>
<header class="top">
  <a href="/" class="mark"><span class="dot"></span><b>downlink</b> <span class="sub">monitor</span></a>
  <nav class="nav">
    <a href="/">llm</a>
    <a href="/feeds">feeds</a>
  </nav>
  <span class="crumb">{{block "crumb" .}}{{end}}</span>
</header>
<div class="wrap">
  {{template "content" .}}
</div>
</body>
</html>
