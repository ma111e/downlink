{{define "title"}}{{.Run.Id}} · LLM Monitor{{end}}
{{define "crumb"}}<a href="/">runs</a> / {{.Run.Id}}{{end}}
{{define "content"}}
  <div class="panel">
    <div class="stat-row">
      <div class="stat"><div class="n">{{.TotalCalls}}</div><div class="l">conversations</div></div>
      <div class="stat"><div class="n">{{comma .TotalTokens}}</div><div class="l">total tokens</div></div>
      <div class="stat"><div class="n">{{shortTime .Run.StartedAt}}</div><div class="l">started</div></div>
      <div class="stat"><div class="n">{{if .Run.FinishedAt}}{{shortTime .Run.FinishedAt}}{{else}}running…{{end}}</div><div class="l">finished</div></div>
    </div>
    {{if .Run.Title}}<div style="margin-top:14px">{{.Run.Title}}</div>{{end}}
    {{if .Run.DigestId}}<div class="muted mono" style="margin-top:6px;font-size:12px">digest {{.Run.DigestId}}</div>{{end}}
  </div>

  {{range .Calls}}
  <details class="call">
    <summary>
      <span class="tag">{{.Label}}</span>
      <span class="meta mono">{{if .ModelName}}{{.ModelName}}{{else}}unknown model{{end}}</span>
      {{if .Err}}<span class="tag err">error</span>{{end}}
      <span class="spacer"></span>
      <span class="meta">{{if .TokensKnown}}{{comma .TotalTokens}} tok ({{comma .PromptTokens}}↑ / {{comma .CompletionTokens}}↓){{else}}tokens n/a{{end}}</span>
      <span class="meta">· {{durMs .DurationMs}}</span>
    </summary>
    <div class="body">
      {{if .Err}}<h4>Error</h4><pre class="text err">{{.Err}}</pre>{{end}}
      <h4>Prompt</h4>
      <pre class="text">{{.Prompt}}</pre>
      <h4>Response</h4>
      <pre class="text">{{.Response}}</pre>
    </div>
  </details>
  {{else}}
  <div class="panel"><div class="empty">No LLM calls recorded for this run.</div></div>
  {{end}}
{{end}}
