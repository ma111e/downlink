{{define "title"}}{{.Run.Id}} · LLM Monitor{{end}}
{{define "crumb"}}<a href="/">runs</a> / {{.Run.Id}}{{end}}
{{define "content"}}
  {{if or .Run.Title .Run.DigestId}}
  <div class="panel pad reveal" style="animation-delay:.04s">
    {{if .Run.Title}}<div style="font-size:15px">{{.Run.Title}}</div>{{end}}
    {{if .Run.DigestId}}<div class="mono faint" style="margin-top:6px;font-size:12px">digest {{.Run.DigestId}}</div>{{end}}
  </div>
  {{end}}

  <div class="section-label reveal" style="animation-delay:.08s;margin:24px 0 14px">Conversations</div>

  {{range .Calls}}
  <details class="call reveal">
    <summary>
      <span class="label">{{.Label}}</span>
      <span class="model">{{if .ModelName}}{{.ModelName}}{{else}}unknown model{{end}}</span>
      {{if .Err}}<span class="chip err">error</span>{{end}}
      <span class="spacer"></span>
      {{if .TokensKnown}}
        <span class="chip u">Sent {{comma .PromptTokens}}</span>
        <span class="chip d">Recv {{comma .CompletionTokens}}</span>
      {{else}}
        <span class="chip na">tokens n/a</span>
      {{end}}
      <span class="model">{{durMs .DurationMs}}</span>
    </summary>
    <div class="body">
      {{if .Err}}<h4>Error</h4><pre class="text err">{{.Err}}</pre>{{end}}
      <h4>Prompt</h4>
      <pre class="text">{{.Prompt}}</pre>
      <h4>Response</h4>
      <pre class="text">{{.Response}}</pre>
    </div>
  </details>
  {{else}}
  <div class="panel"><div class="empty">No LLM calls recorded for this run.</div></div>
  {{end}}
{{end}}
