{{define "title"}}Feed Refreshes · downlink{{end}}
{{define "crumb"}}feed refresh history{{end}}
{{define "content"}}
  <div class="stats">
    <div class="stat reveal" style="animation-delay:.02s">
      <div class="l">Runs</div><div class="n">{{.Stats.Runs}}</div>
      <div class="sub">refresh cycles</div>
    </div>
    <div class="stat reveal" style="animation-delay:.06s">
      <div class="l">Feeds</div><div class="n">{{comma .Stats.Feeds}}</div>
      <div class="sub">feeds refreshed</div>
    </div>
    <div class="stat up reveal" style="animation-delay:.1s">
      <div class="l">Fetched</div><div class="n">{{comma .Stats.Fetched}}</div>
      <div class="sub">items seen</div>
    </div>
    <div class="stat reveal" style="animation-delay:.14s">
      <div class="l">Stored</div><div class="n">{{comma .Stats.Stored}}</div>
      <div class="sub">articles saved</div>
    </div>
    <div class="stat down reveal" style="animation-delay:.18s">
      <div class="l">Failed</div><div class="n">{{comma .Stats.Failed}}</div>
      <div class="sub">feed failures</div>
    </div>
    <div class="stat reveal" style="animation-delay:.22s">
      <div class="l">Sanitized</div><div class="n">{{comma .Stats.Warned}}</div>
      <div class="sub">items cleaned</div>
    </div>
  </div>

  <div class="panel reveal" style="animation-delay:.24s">
    <table>
      <thead>
        <tr>
          <th>Started</th>
          <th>Run</th>
          <th>Trigger</th>
          <th></th>
          <th class="num">Feeds</th>
          <th class="num">Fetched</th>
          <th class="num">Stored</th>
          <th class="num">Errors</th>
          <th class="num">Sanitized</th>
        </tr>
      </thead>
      <tbody>
        {{range .Runs}}
        <tr>
          <td class="muted mono" style="font-size:12px">{{shortTime .StartedAt}}</td>
          <td><a class="runid rowlink" href="/feed-refresh/{{.Id}}">{{.Id}}</a></td>
          <td class="mono faint" style="font-size:12px">{{.Trigger}}</td>
          <td>{{ratioBar .OkCount .FailCount}}</td>
          <td class="num muted">{{.FeedCount}}</td>
          <td class="num up">{{comma .TotalFetched}}</td>
          <td class="num">{{comma .TotalStored}}</td>
          <td class="num {{if .FailCount}}down{{else}}muted{{end}}">{{if or .FailCount .ErrorCount}}{{add .FailCount .ErrorCount}}{{else}}—{{end}}</td>
          <td class="num muted">{{if .WarningCount}}{{comma .WarningCount}}{{else}}—{{end}}</td>
        </tr>
        {{else}}
        <tr><td colspan="9" class="empty">No feed refreshes recorded yet.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
{{end}}
