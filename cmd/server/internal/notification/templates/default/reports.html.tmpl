<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe/sources/reports pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
  } catch(e){}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<meta name="description" content="DOWNLINK · search the reports collected across the archive">
<meta property="og:type" content="website">
<meta property="og:title" content="DOWNLINK // reports">
<meta property="og:description" content="Search the third-party reports and research referenced across the DOWNLINK digests.">
<title>DOWNLINK // reports</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Sans+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
@view-transition { navigation: auto; }
@keyframes vt-slide-fade-out { to { opacity: 0; transform: translateX(24px); } }
@keyframes vt-slide-fade-in { from { opacity: 0; transform: translateX(-24px); } }
@media (prefers-reduced-motion: no-preference) {
  ::view-transition-old(root) { animation: vt-slide-fade-out 220ms cubic-bezier(0.4, 0, 1, 1) both; }
  ::view-transition-new(root) { animation: vt-slide-fade-in 320ms cubic-bezier(0, 0, 0.2, 1) 120ms both; }
}
:root {
  color-scheme: dark;
  --bg: #0a0d10; --bg-2: #0e1216; --panel: #11161b; --panel-2: #161c22;
  --line: #1e262e; --line-2: #2a343d;
  --ink: #d8e2ea; --ink-dim: #8a98a5; --ink-faint: #5a6772;
  --accent: #6ad1c4; --accent-2: #f0c674;
  --must: #f06b6b; --should: #f0c674; --may: #6ad1c4; --opt: #8a98a5;
  --grid-dot: rgba(255,255,255,.045); --halo: rgba(106,209,196,.18);
}
html[data-theme="contrast"] {
  color-scheme: dark;
  --bg: #000; --bg-2: #050505; --panel: #0a0a0a; --panel-2: #111;
  --line: #2a2a2a; --line-2: #3a3a3a;
  --ink: #fff; --ink-dim: #c7c7c7; --ink-faint: #888;
  --accent: #00ffd1; --accent-2: #ffd24a;
  --must: #ff5050; --should: #ffd24a; --may: #00ffd1; --opt: #aaa;
  --grid-dot: rgba(255,255,255,.08); --halo: rgba(0,255,209,.25);
}
html[data-theme="mono"] {
  color-scheme: dark;
  --bg: #0c0c0c; --bg-2: #101010; --panel: #131313; --panel-2: #181818;
  --line: #242424; --line-2: #333;
  --ink: #e6e6e6; --ink-dim: #9a9a9a; --ink-faint: #5e5e5e;
  --accent: #e6e6e6; --accent-2: #bdbdbd;
  --must: #f0f0f0; --should: #c8c8c8; --may: #9a9a9a; --opt: #6a6a6a;
  --grid-dot: rgba(255,255,255,.04); --halo: rgba(255,255,255,.08);
}
html[data-theme="light"] {
  color-scheme: light;
  --bg: #efeeea; --bg-2: #e8e7e2; --panel: #fafaf8; --panel-2: #f0efeb;
  --line: #d3d2cc; --line-2: #b8b7b0;
  --ink: #0d0c0a; --ink-dim: #273f4f; --ink-faint: #5c6e78;
  --accent: oklch(66% 0.18 45); --accent-2: oklch(66% 0.18 78);
  --must: oklch(66% 0.18 25); --should: oklch(66% 0.18 67); --may: oklch(66% 0.18 250); --opt: #5c6e78;
  --grid-dot: rgba(0,0,0,.035); --halo: rgba(254,119,67,.15);
}
html[data-theme="colorblind"] {
  color-scheme: light;
  --bg: #efeeea; --bg-2: #e8e7e2; --panel: #fafaf8; --panel-2: #f0efeb;
  --line: #d3d2cc; --line-2: #b8b7b0;
  --ink: #0d0c0a; --ink-dim: #273f4f; --ink-faint: #5c6e78;
  --accent: #0072b2; --accent-2: #8a6d00;
  --must: #c44601; --should: #8a6d00; --may: #2f79a5; --opt: #5c6e78;
  --grid-dot: rgba(0,0,0,.035); --halo: rgba(0,114,178,.15);
}
html[data-theme="pastel"] {
  color-scheme: light;
  --bg: #faf6e6; --bg-2: #f1ead2; --panel: #fffdf4; --panel-2: #f5efda;
  --line: #e6dcbf; --line-2: #d2c5a2;
  --ink: #3a3137; --ink-dim: #6c5560; --ink-faint: #9c8a86;
  --accent: #1f9d8f; --accent-2: #e08a2e;
  --must: #d9534f; --should: #e08a2e; --may: #4a90d9; --opt: #9c8a86;
  --grid-dot: rgba(0,0,0,.03); --halo: rgba(31,157,143,.15);
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; overflow-x: hidden; }
body {
  min-height: 100vh;
  background: var(--bg);
  background-image: radial-gradient(circle at 1px 1px, var(--grid-dot) 1px, transparent 0);
  background-attachment: fixed;
  background-size: 18px 18px;
  color: var(--ink);
  font: clamp(15px, 1dvw, 20px)/1.5 "IBM Plex Sans", system-ui, sans-serif;
}
::selection { background: var(--accent); color: #001210; }
a { color: inherit; text-decoration: none; }
button, input, select { font: inherit; color: inherit; }
#app { max-width: 1280px; margin: 0 auto; padding: 28px 28px 96px; }
.topbar { display: flex; align-items: center; gap: 16px; border-bottom: 1px solid var(--line); margin-bottom: 22px; padding-bottom: 14px; }
.brand { display: flex; align-items: center; gap: 10px; letter-spacing: .08em; text-decoration: none; color: inherit; }
.brand .brand-mark { width: auto; height: 2.3rem; color: var(--accent); flex: none; }
.brand .word { font-family: "IBM Plex Sans Condensed", "IBM Plex Sans", sans-serif; font-size: 1.57rem; font-weight: 700; }
.brand .slash { color: var(--ink-faint); }
.brand .sub { color: var(--ink-dim); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .12em; text-transform: uppercase; }
.topbar .spacer { flex: 1; }
.topbar-theme-select {
  font: 12px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .06em; text-transform: uppercase;
  color: var(--ink-dim); border: 1px solid var(--line-2); background: var(--panel);
  padding: 4px 28px 4px 9px; border-radius: 2px; cursor: pointer; line-height: 1;
  appearance: none; -webkit-appearance: none;
  background-image: linear-gradient(45deg, transparent 50%, var(--ink-faint) 50%), linear-gradient(135deg, var(--ink-faint) 50%, transparent 50%);
  background-position: calc(100% - 10px) 50%, calc(100% - 6px) 50%;
  background-size: 4px 4px, 4px 4px; background-repeat: no-repeat;
}
.topbar-theme-select:hover { border-color: var(--accent); color: var(--ink); }
.topbar-theme-select:focus-visible { outline: 1px solid var(--accent); outline-offset: 1px; }
.meta { color: var(--ink-dim); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .06em; }
.meta b { color: var(--ink); font-weight: 500; }
@keyframes pulse { 0% { box-shadow: 0 0 0 0 var(--halo); } 70% { box-shadow: 0 0 0 10px rgba(0,0,0,0); } 100% { box-shadow: 0 0 0 0 rgba(0,0,0,0); } }
.page-head { margin: 4px 0 20px; }
.page-head h1 { font-family: "IBM Plex Sans Condensed", "IBM Plex Sans", sans-serif; font-size: 1.71rem; font-weight: 700; letter-spacing: .02em; margin: 0 0 6px; }
.page-head p { margin: 0; color: var(--ink-dim); font-size: 13px; max-width: 66ch; }

/* controls */
.controls { display: flex; flex-direction: column; gap: 12px; margin-bottom: 22px; }
.searchrow { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.search {
  flex: 1; min-width: 240px;
  background: var(--panel); border: 1px solid var(--line-2); color: var(--ink);
  padding: 10px 12px; border-radius: 2px;
}
.search:focus-visible { outline: 1px solid var(--accent); outline-offset: 1px; border-color: var(--accent); }
.sortbtn {
  font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .06em; text-transform: uppercase;
  color: var(--ink-dim); border: 1px solid var(--line-2); background: var(--panel);
  padding: 9px 12px; border-radius: 2px; cursor: pointer;
}
.sortbtn:hover { border-color: var(--accent); color: var(--ink); }
.chiprow { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.chiprow .label { font: 10px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-faint); margin-right: 4px; }
.chip {
  font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .04em;
  color: var(--ink-dim); border: 1px solid var(--line-2); background: var(--panel);
  padding: 4px 9px; border-radius: 999px; cursor: pointer; white-space: nowrap;
  transition: border-color .12s ease, color .12s ease, background .12s ease;
}
.chip:hover { border-color: var(--accent); color: var(--ink); }
.chip.on { border-color: var(--accent); color: var(--bg); background: var(--accent); }
.chip .ct { color: var(--ink-faint); margin-left: 5px; }
.chip.on .ct { color: var(--bg); opacity: .7; }

/* results */
.count { color: var(--ink-faint); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .06em; margin-bottom: 12px; }
.reports { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
.rep { border: 1px solid var(--line); background: linear-gradient(180deg, var(--panel-2), var(--panel)); padding: 14px 16px; transition: border-color .15s ease; }
.rep:hover { border-color: var(--line-2); }
.rep-top { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
.rep-title { font-weight: 600; font-size: 15px; color: var(--ink); }
.rep-title:hover { color: var(--accent); }
.badge { font: 9px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .1em; text-transform: uppercase; padding: 2px 6px; border-radius: 2px; border: 1px solid var(--line-2); color: var(--ink-dim); }
.badge.primary { border-color: var(--must); color: var(--must); }
.badge.cat { border-color: var(--accent); color: var(--accent); }
.rep-meta { margin-top: 6px; color: var(--ink-faint); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .04em; display: flex; gap: 12px; flex-wrap: wrap; }
.rep-meta .pub { color: var(--ink-dim); }
.rep-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
.tag { font: 10px "IBM Plex Mono", ui-monospace, monospace; color: var(--ink-dim); border: 1px solid var(--line); background: var(--bg-2); padding: 2px 7px; border-radius: 999px; cursor: pointer; }
.tag:hover { border-color: var(--accent); color: var(--ink); }
.tag.on { border-color: var(--accent); color: var(--accent); }
.srctoggle { margin-top: 10px; background: none; border: 0; padding: 0; cursor: pointer; color: var(--ink-faint); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .04em; }
.srctoggle:hover { color: var(--accent); }
.sources { margin: 8px 0 0; padding: 10px 0 0; border-top: 1px dashed var(--line); list-style: none; display: none; flex-direction: column; gap: 10px; }
.sources.open { display: flex; }
.srcitem .srctitle { font-weight: 500; font-size: 13px; color: var(--ink); }
.srcitem .srctitle:hover { color: var(--accent); }
.srcitem .srcdate { color: var(--ink-faint); font: 10px "IBM Plex Mono", ui-monospace, monospace; margin-left: 8px; }
.srcitem .srcdesc { color: var(--ink-dim); font-size: 12.5px; margin-top: 3px; }
.srcitem .srcctx { color: var(--ink-faint); font-size: 12px; font-style: italic; margin-top: 3px; }
.empty { border: 1px dashed var(--line); background: var(--panel); color: var(--ink-faint); font: 12px "IBM Plex Mono", ui-monospace, monospace; padding: 60px 20px; text-align: center; }
.foot { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 8px; border-top: 1px solid var(--line); color: var(--ink-faint); font: 11px "IBM Plex Mono", ui-monospace, monospace; letter-spacing: .06em; margin-top: 36px; padding-top: 16px; }
.foot a:hover { color: var(--accent); }
</style>
</head>
