      {{end}}
    </select>
  </div>

  <header class="page-head">
    <h1>Reports</h1>
    <p>Third-party reports, research, advisories and whitepapers referenced across the digests — deduplicated, with the articles and tags they were referenced from.</p>
  </header>

  <div class="controls">
    <div class="searchrow">
      <input class="search" id="search" type="search" placeholder="Search title, publisher, context, tags…" autocomplete="off" spellcheck="false">
      <button class="sortbtn" id="sort" type="button" title="Toggle sort order">sort: most referenced</button>
    </div>
    <div class="chiprow" id="catrow"><span class="label">category</span></div>
    <div class="chiprow" id="tagrow"><span class="label">tags</span></div>
  </div>

  <div class="count" id="count"></div>
  <ul class="reports" id="list"></ul>
  <div class="empty" id="empty" style="display:none">No reports match your filters.</div>

  <footer class="foot">
    <span>DOWNLINK · reports · {{.Commit}}</span>
    <span><a href="sources.html">sources</a> · <a href="index.html">&larr; back to archive</a></span>
