<!DOCTYPE html>
<html lang="en" data-theme="{{ .Theme }}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
  } catch(e){}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<meta name="description" content="DOWNLINK · Triage — {{ .TimeWindow }} digest">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ .DigestTitle }} — DOWNLINK Triage">
<meta property="og:description" content="Swipe-triage the {{ .TimeWindow }} intelligence digest.">
<title>DOWNLINK · Triage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>{{ .PaletteCSS }}
{{ .StyleCSS }}</style>{{ .StyleLink }}
</head>
<body>
<div id="root"></div>
<script type="application/json" id="dl-articles">{{ .ArticlesJSON }}</script>
<script type="application/json" id="dl-meta">{{ .MetaJSON }}</script>
{{if .ScriptJS}}<script type="module">{{ .ScriptJS }}</script>{{end}}{{ .ScriptSrc }}
</body>
</html>
