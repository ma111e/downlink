<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe/sources pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
  } catch(e){}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<meta name="description" content="DOWNLINK · the feeds this archive is built from">
