<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
    // Normalize wide displays (e.g. 4K at 100% OS scale) to a ~2560px baseline so the page
    // renders at the same apparent size as a 2K screen, removing the need for manual browser
    // zoom. screen.width is CSS px (already reflects OS scaling) and is immune to CSS zoom,
    // so this cannot feed back into a layout loop. An explicit saved value overrides auto.
    var z = localStorage.getItem('downlink.zoom');
    z = (z === null) ? Math.max(1, Math.round(screen.width / 2560 * 100) / 100)
                     : (parseFloat(z) || 1);
    if (z !== 1) document.documentElement.style.zoom = z;
    // Learning master on/off + help level (1=Minimal, 2=Partial, 3=Full). The level decides how
    // much jargon shows (term shown when level >= its tier); it defaults to Full (3) when unset.
    // Per-feature sub-toggles default on unless explicitly turned off.
    var lvl = localStorage.getItem('downlink.help.level');
    if (lvl !== '1' && lvl !== '2' && lvl !== '3') lvl = '3';
    if (localStorage.getItem('downlink.learning') === 'on') {
      var d = document.documentElement.dataset;
      d.learning = 'on';
      d.helpLevel = lvl;
      d.learnPlain = localStorage.getItem('downlink.learn.plain') === 'off' ? 'off' : 'on';
      d.learnGlossary = localStorage.getItem('downlink.learn.glossary') === 'off' ? 'off' : 'on';
      d.learnDefine = localStorage.getItem('downlink.learn.define') === 'off' ? 'off' : 'on';
    }
  } catch(e){}
})();
</script>
