<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
    // Learning master on/off + help level (1=Pro, 2=Standard, 3=Novice). The level decides how
    // much jargon shows (term shown when level >= its tier); it defaults to Novice (3) when unset.
    // Per-feature sub-toggles default on unless explicitly turned off.
    var lvl = localStorage.getItem('downlink.help.level');
    if (lvl !== '1' && lvl !== '2' && lvl !== '3') lvl = '3';
    if (localStorage.getItem('downlink.learning') === 'on') {
      var d = document.documentElement.dataset;
      d.learning = 'on';
      d.helpLevel = lvl;
      d.learnPlain = localStorage.getItem('downlink.learn.plain') === 'off' ? 'off' : 'on';
      d.learnGlossary = localStorage.getItem('downlink.learn.glossary') === 'off' ? 'off' : 'on';
      d.learnDefine = localStorage.getItem('downlink.learn.define') === 'off' ? 'off' : 'on';
    }
  } catch(e){}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<meta name="description" content="{{if .DigestTitle}}{{.DigestTitle}} — {{end}}{{.ArticleCount}} articles · {{.TimeWindow}} intelligence window">
<meta property="og:type" content="article">
<meta property="og:title" content="{{if .DigestTitle}}{{.DigestTitle}} — DOWNLINK{{else}}DOWNLINK Intelligence Digest{{end}}">
<meta property="og:description" content="{{.ArticleCount}} articles curated from a {{.TimeWindow}} window.">
{{if .DigestTitle}}<title>{{.DigestTitle}} — DOWNLINK</title>{{else}}<title>DOWNLINK — {{.StartedAt}}</title>{{end}}
<link rel="icon" type="image/x-icon" href="./favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="./favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="./favicon-32.png">
<link rel="icon" type="image/png" sizes="48x48" href="./favicon-48.png">
<link rel="apple-touch-icon" sizes="128x128" href="./icon-128.png">
