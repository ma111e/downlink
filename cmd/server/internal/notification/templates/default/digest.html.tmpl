<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* cross-document page transition. The destination page's CSS drives the animation,
   so landing on a digest (drilling "in" from the index) plays right-to-left:
   the outgoing index slides left while the digest slides in from the right.
   Unsupported browsers (e.g. Firefox) navigate instantly. */
@view-transition { navigation: auto; }
@keyframes vt-slide-fade-out {
  to { opacity: 0; transform: translateX(-24px); }
}
@keyframes vt-slide-fade-in {
  from { opacity: 0; transform: translateX(24px); }
}
@media (prefers-reduced-motion: no-preference) {
  ::view-transition-old(root) {
    animation: vt-slide-fade-out 220ms cubic-bezier(0.4, 0, 1, 1) both;
  }
  ::view-transition-new(root) {
    animation: vt-slide-fade-in 320ms cubic-bezier(0, 0, 0.2, 1) 120ms both;
  }
}

:root {
  --bg:      #0b0b0e;
  --surface: #111116;
  --surface2:#15151c;
  --surface-raised: #1c1c26;   /* elevated card: a step lighter than --surface */
  --border:  #1c1c25;
  --border2: #252530;
  --text:    #dddde8;
  --text2:   #a8a8be;
  --text3:   #4a4a60;
  --cyan:    oklch(74% 0.14 196);
  --green:   oklch(74% 0.16 150);
  --violet:  oklch(70% 0.16 295);
  --must:    oklch(66% 0.15 38);
  --should:  oklch(73% 0.16 60);
  --may:     oklch(65% 0.13 250);
  --mono:    'IBM Plex Mono', 'SF Mono', 'Fira Code', Consolas, monospace;
  --sans:    'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  --radius:  4px;
  --cat-research: oklch(72% 0.19 320);
  --cat-advisory: oklch(74% 0.18 44);
  --cat-news:     oklch(72% 0.15 220);
  --cat-opinion:  oklch(70% 0.17 350);
  --cat-guide:    oklch(76% 0.15 130);
  --cat-commercial:   oklch(80% 0.15 85);
  --cat-sponsored:    oklch(72% 0.16 300);
  --cat-announcement: oklch(75% 0.14 160);
  --dot:     #ffffff08;
}

/* Light theme: palette anchored on #EFEEEA (warm cream bg), #FE7743 (orange accent),
   #273F4F (dark teal for muted text), #000000 (near-black text). */
html[data-theme="light"] {
  --bg:      #efeeea;  /* reference warm cream                     — */
  --surface: #fafaf8;  /* warm near-white cards                    — */
  --surface2:#e8e7e2;  /* deeper cream for alt surfaces            — */
  --surface-raised: #ffffff;  /* elevated card: pure white, lighter than --surface */
  --border:  #d3d2cc;  /* warm border                             1.3:1 on bg */
  --border2: #b8b7b0;  /* stronger warm border                    1.7:1 on bg */
  --text:    #0d0c0a;  /* warm near-black                        16.8:1 on bg */
  --text2:   #273f4f;  /* reference dark teal                     9.5:1 on bg */
  --text3:   #5c6e78;  /* lightened teal                          4.6:1 on bg */
  /* Homogeneous accents: uniform OKLCH L 66% / C 0.18, hue only varies. */
  --cyan:    oklch(66% 0.18 45);   /* brand orange: primary accent */
  --green:   oklch(66% 0.18 150);
  --violet:  oklch(66% 0.18 300);
  --must:    oklch(66% 0.18 25);
  --should:  oklch(66% 0.18 67);
  --may:     oklch(66% 0.18 250);
  --cat-research:     oklch(66% 0.18 328);
  --cat-advisory:     oklch(66% 0.18 40);
  --cat-news:         oklch(66% 0.18 236);
  --cat-opinion:      oklch(66% 0.18 358);
  --cat-guide:        oklch(66% 0.18 150);
  --cat-commercial:   oklch(66% 0.18 78);
  --cat-sponsored:    oklch(66% 0.18 300);
  --cat-announcement: oklch(66% 0.18 168);
  --dot:     rgba(0,0,0,.035);
}

/* Contrast theme: pure black, max-legibility whites, vivid accents. */
html[data-theme="contrast"] {
  --bg:      #000000;
  --surface: #0a0a0a;
  --surface2:#111111;
  --surface-raised: #181818;   /* elevated card: a step lighter than --surface */
  --border:  #2a2a2a;
  --border2: #3a3a3a;
  --text:    #ffffff;
  --text2:   #c7c7c7;
  --text3:   #888888;
  --cyan:    #00ffd1;
  --green:   #00ff95;
  --violet:  #c08cff;
  --must:    #ff5050;
  --should:  #ffd24a;
  --may:     #00ffd1;
  --cat-research:     #00ffd1;
  --cat-advisory:     #ff8a3a;
  --cat-news:         #4ab8ff;
  --cat-opinion:      #ff6ec7;
  --cat-guide:        #5dff8f;
  --cat-commercial:   #ffd24a;
  --cat-sponsored:    #c08cff;
  --cat-announcement: #3affc0;
  --dot:     rgba(255,255,255,.08);
}

/* Mono theme: grayscale, no chroma. */
html[data-theme="mono"] {
  --bg:      #0c0c0c;
  --surface: #131313;
  --surface2:#181818;
  --surface-raised: #1f1f1f;   /* elevated card: a step lighter than --surface */
  --border:  #242424;
  --border2: #333333;
  --text:    #e6e6e6;
  --text2:   #9a9a9a;
  --text3:   #5e5e5e;
  --cyan:    #e6e6e6;
  --green:   #cfcfcf;
  --violet:  #bdbdbd;
  --must:    #f0f0f0;
  --should:  #c8c8c8;
  --may:     #9a9a9a;
  --cat-research:     #e6e6e6;
  --cat-advisory:     #cfcfcf;
  --cat-news:         #bdbdbd;
  --cat-opinion:      #d6d6d6;
  --cat-guide:        #c8c8c8;
  --cat-commercial:   #b0b0b0;
  --cat-sponsored:    #a8a8a8;
  --cat-announcement: #bcbcbc;
  --dot:     rgba(255,255,255,.04);
}

/* Colorblind theme: light base, colorblind-safe Okabe-Ito accents so priorities
   and categories stay distinct under protan/deutan/tritan vision. Accents are tuned
   for vividness while all meeting WCAG AA (>=4.5:1) on the cream bg. research is green
   and news blue for a clear hue split; note green/blue can still converge under tritan
   deficiency, and research's green sits in the same family as guide's bluish-green. */
html[data-theme="colorblind"] {
  --bg:      #efeeea;  /* light-theme neutrals, reused */
  --surface: #fafaf8;
  --surface2:#e8e7e2;
  --surface-raised: #ffffff;  /* elevated card: pure white, lighter than --surface */
  --border:  #d3d2cc;
  --border2: #b8b7b0;
  --text:    #0d0c0a;
  --text2:   #273f4f;
  --text3:   #5c6e78;
  --cyan:    #0071b0;  /* accent/links: Okabe blue */
  --green:   #0d7b4a;  /* bluish-green (no pure green) */
  --violet:  #8f4acc;  /* purple */
  --must:    #be4401;  /* vermillion */
  --should:  #856900;  /* dark gold */
  --may:     #1972a7;  /* teal-blue */
  --cat-research:     #197d1e;  /* green */
  --cat-advisory:     #be4401;  /* vermillion */
  --cat-news:         #0071b0;  /* blue */
  --cat-opinion:      #c42787;  /* reddish-purple */
  --cat-guide:        #0d7b4a;  /* bluish-green */
  --cat-commercial:   #856900;  /* gold */
  --cat-sponsored:    #8f4acc;  /* purple */
  --cat-announcement: #007a6d;  /* teal */
  --dot:     rgba(0,0,0,.035);
}

/* Pastel theme: soft cream bg (#FAF6E6), mint/coral/pink palette, deep warm-plum text.
   Accents are deepened versions of the pastels so they stay legible on the light bg. */
html[data-theme="pastel"] {
  --bg:      #faf6e6;  /* soft cream                              — */
  --surface: #fffdf4;  /* warm near-white cards                   — */
  --surface2:#f1ead2;  /* deeper cream for alt surfaces           — */
  --surface-raised: #fffdf4;  /* elevated card: same warm near-white as --surface */
  --border:  #e6dcbf;  /* warm border                            1.2:1 on bg */
  --border2: #d2c5a2;  /* stronger warm border                   1.5:1 on bg */
  --text:    #3a3137;  /* deep warm plum                        ~10:1 on bg */
  --text2:   #6c5560;  /* muted mauve                            ~5:1 on bg */
  --text3:   #9c8a86;  /* faint warm taupe */
  --cyan:    #1f9d8f;  /* deepened mint: primary accent */
  --green:   #2f9e63;  /* soft green */
  --violet:  #8257c2;  /* soft purple */
  --must:    #d9534f;  /* coral-red */
  --should:  #e08a2e;  /* peach-amber */
  --may:     #4a90d9;  /* soft blue */
  --cat-research: #a05fc0;  /* purple */
  --cat-advisory: #e0655c;  /* coral */
  --cat-news:     #3f8fd0;  /* blue */
  --cat-opinion:  #de6b94;  /* rose-pink */
  --cat-guide:    #2faa8e;  /* mint-green */
  --cat-commercial:   #d99a2b;  /* gold */
  --cat-sponsored:    #8c6dd0;  /* violet */
  --cat-announcement: #2ba88f;  /* teal-green */
  --dot:     rgba(0,0,0,.03);
}

/* Per-theme source-color palette (--p0..--pN), generated server-side. */
{{.PaletteCSS}}

html {
  background: var(--bg);
  background-image: radial-gradient(circle, var(--dot) 1px, transparent 1px);
  background-size: 24px 24px;
  color: var(--text);
  font-family: var(--sans);
  font-size: clamp(15px, 1dvw, 20px);
  line-height: 1.6;
  scroll-behavior: smooth;
  overflow-x: clip;   /* swallow the full-bleed nav's 100vw overflow without making html a scroll container (keeps sticky) */
}
body { min-height: 100vh; max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; }
::selection { background: color-mix(in oklch, var(--cyan) 25%, transparent); }
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

a { color: var(--cyan); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── animations ──────────────────────────────────── */
@keyframes target-pulse {
  0%,100% { border-color: var(--cyan); }
  50%      { border-color: var(--border); }
}

/* ── section label ───────────────────────────────── */
.section-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  color: var(--text3);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-label::before { content: "//"; opacity: 0.5; font-size: 11px; }

/* ── nav ─────────────────────────────────────────── */
#nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: color-mix(in oklch, var(--bg) 90%, transparent);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  /* full-bleed: break out of the 900px body column to span the viewport */
  width: 100vw;
  margin-left: calc(50% - 50vw);
  padding: 0 24px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-left {
  display: flex;
  align-items: center;
  gap: 16px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0;
  text-decoration: none;
}
.nav-logo:hover { text-decoration: none; }
.nav-logo-down { font-family: var(--mono); font-weight: 600; font-size: 16px; letter-spacing: 0.14em; color: var(--text); }
.nav-logo-link { font-family: var(--mono); font-weight: 600; font-size: 16px; letter-spacing: 0.14em; color: var(--cyan); margin-right: 12px; }
.nav-logo-ver {
  margin-left: 10px;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--cyan);
  letter-spacing: 0.1em;
  border: 1px solid color-mix(in oklch, var(--cyan) 30%, transparent);
  background: color-mix(in oklch, var(--cyan) 7%, transparent);
  padding: 1px 6px;
  border-radius: 2px;
}
.nav-meta {
  display: flex;
  flex-direction: column;
  justify-content: center;
  line-height: 1.3;
}
.nav-date  { font-family: var(--mono); font-size: 11px; color: var(--text2); letter-spacing: 0.06em; }
.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.nav-window { font-family: var(--mono); font-size: 11px; color: var(--text3); letter-spacing: 0.06em; }
.nav-swipe {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--cyan);
  border: 1px solid color-mix(in oklch, var(--cyan) 35%, transparent);
  background: color-mix(in oklch, var(--cyan) 8%, transparent);
  padding: 3px 10px;
  border-radius: 2px;
  text-decoration: none;
  text-transform: uppercase;
  white-space: nowrap;
}
.nav-swipe:hover { border-color: var(--cyan); color: var(--text); text-decoration: none; }
.nav-count {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text2);
  letter-spacing: 0.08em;
  border: 1px solid var(--border2);
  background: var(--surface);
  padding: 3px 10px;
  border-radius: 2px;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}
.nav-count-dot { color: var(--should); }
/* theme picker: full theme choice sitting beside the quick light/dark toggle */
.nav-theme-select {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 2px;
  padding: 4px 22px 4px 8px;
  cursor: pointer;
  text-transform: uppercase;
  appearance: none;
  -webkit-appearance: none;
  background-image: linear-gradient(45deg, transparent 50%, var(--text3) 50%),
                    linear-gradient(135deg, var(--text3) 50%, transparent 50%);
  background-position: calc(100% - 10px) 50%, calc(100% - 6px) 50%;
  background-size: 4px 4px, 4px 4px;
  background-repeat: no-repeat;
}
.nav-theme-select:hover { border-color: var(--cyan); color: var(--text); }
.nav-theme-select:focus-visible { outline: 1px solid var(--cyan); outline-offset: 1px; }
/* Learning mode: a master switch that reveals the newcomer aids, plus a caret-opened card of
   per-feature switches. */
.nav-learn { position: relative; display: inline-flex; align-items: center; gap: 4px; }
/* Master LEARNING on/off pill. */
.nav-learn-switch {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 24px;
  box-sizing: border-box;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 2px;
  padding: 0 8px;
  cursor: pointer;
  text-transform: uppercase;
}
.nav-learn-switch:hover { border-color: var(--should); color: var(--text); }
.nav-learn-switch:focus-visible { outline: 1px solid var(--should); outline-offset: 1px; }
.nav-learn-track {
  position: relative;
  width: 20px;
  height: 11px;
  border-radius: 999px;
  background: var(--border2);
  transition: background .15s;
  flex: none;
}
.nav-learn-knob {
  position: absolute;
  top: 1px;
  left: 1px;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--text3);
  transition: transform .15s, background .15s;
}
.nav-learn-switch[aria-checked="true"] {
  color: var(--should);
  border-color: color-mix(in oklch, var(--should) 45%, transparent);
  background: color-mix(in oklch, var(--should) 10%, transparent);
}
.nav-learn-switch[aria-checked="true"] .nav-learn-track { background: color-mix(in oklch, var(--should) 60%, transparent); }
.nav-learn-switch[aria-checked="true"] .nav-learn-knob { transform: translateX(9px); background: var(--should); }
/* Compact level indicator (mirrors the in-menu slider position). Visible only when learning is on,
   but its box is always reserved so toggling never shifts the row. */
.nav-help-mini {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 3px;
  /* Match the caret box height so the dots get a roomy, transparent square hit area. */
  height: 24px;
  box-sizing: border-box;
  padding: 0 6px;
  border: 1px solid transparent;
  border-radius: 2px;
  visibility: hidden;
  cursor: pointer;
  position: relative;
}
html[data-learning="on"] .nav-help-mini { visibility: visible; }
.nav-help-mini-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--text3); transition: background .12s; }
.nav-help-mini-dot.is-active { background: var(--should); }
/* Transient label that flashes the new help level next to the dots after a change.
   Absolutely positioned so it never reflows the nav row. */
.nav-help-flash {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-top: 2px;
  font-size: 10px;
  color: var(--should);
  white-space: nowrap;
  opacity: 0;
  transition: opacity .2s;
  pointer-events: none;
}
.nav-help-flash.is-shown { opacity: 1; }
.nav-learn-caret {
  height: 24px;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  font-size: 10px;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 2px;
  padding: 0 7px;
  cursor: pointer;
  line-height: 1;
  /* Always reserve the caret's box; only its visibility toggles, so the row never shifts. */
  visibility: hidden;
  pointer-events: none;
}
html[data-learning="on"] .nav-learn-caret { visibility: visible; pointer-events: auto; }
.nav-learn-caret:hover { border-color: var(--should); color: var(--text); }
.nav-learn-caret[aria-expanded="true"] { color: var(--should); border-color: color-mix(in oklch, var(--should) 45%, transparent); }
.learn-card {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  z-index: 50;
  min-width: 200px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px;
  box-shadow: 0 8px 28px rgba(0,0,0,.4);
}
.learn-card[hidden] { display: none; }
.learn-card-title {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text3);
  padding: 2px 4px 6px;
}
/* In-menu help-level slider: track + 3 stops (left=Novice/most help, right=Pro/least) + knob. */
.help-slider {
  position: relative;
  width: auto;
  height: 20px;
  margin: 0 4px 2px;
  cursor: pointer;
  touch-action: none;
  border-radius: 999px;
}
.help-slider:focus-visible { outline: 1px solid var(--should); outline-offset: 2px; }
.help-slider-track {
  position: absolute;
  top: 50%;
  left: 5px;
  right: 5px;
  height: 4px;
  transform: translateY(-50%);
  background: var(--border2);
  border-radius: 999px;
}
.help-slider-dot {
  position: absolute;
  top: 50%;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--text3);
  transform: translate(-50%, -50%);
  transition: background .12s;
}
.help-slider-dot[data-pos="0"] { left: 5px; }
.help-slider-dot[data-pos="1"] { left: 50%; }
.help-slider-dot[data-pos="2"] { left: calc(100% - 5px); }
.help-slider-dot.is-active { background: var(--should); }
.help-slider-knob {
  position: absolute;
  top: 50%;
  left: 5px;
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: var(--text);
  border: 1px solid var(--border);
  transform: translate(-50%, -50%);
  transition: left .12s;
  pointer-events: none;
  box-shadow: 0 1px 3px rgba(0,0,0,.4);
}
.help-slider-ends {
  display: flex;
  justify-content: space-between;
  padding: 0 4px 6px;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text3);
}
.learn-feature {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  gap: 12px;
  background: none;
  border: none;
  border-radius: 4px;
  padding: 6px 4px;
  cursor: pointer;
  color: var(--text2);
  font-size: 12px;
}
.learn-feature:hover { background: color-mix(in oklch, var(--should) 8%, transparent); color: var(--text); }
.learn-feature:focus-visible { outline: 1px solid var(--should); outline-offset: -1px; }
.learn-switch {
  position: relative;
  width: 26px;
  height: 14px;
  border-radius: 999px;
  background: var(--border2);
  transition: background .15s;
  flex: none;
}
.learn-switch-knob {
  position: absolute;
  top: 2px;
  left: 2px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--text3);
  transition: transform .15s, background .15s;
}
.learn-feature[aria-checked="true"] { color: var(--text); }
.learn-feature[aria-checked="true"] .learn-switch { background: color-mix(in oklch, var(--should) 60%, transparent); }
.learn-feature[aria-checked="true"] .learn-switch-knob { transform: translateX(12px); background: var(--should); }

/* ── provider/model switcher ─────────────────────── */
.nav-switcher {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 2px;
  padding: 3px 8px;
  cursor: pointer;
  text-transform: uppercase;
  white-space: nowrap;
  appearance: none;
  -webkit-appearance: none;
  background-image: linear-gradient(45deg, transparent 50%, var(--text3) 50%),
                    linear-gradient(135deg, var(--text3) 50%, transparent 50%);
  background-position: calc(100% - 10px) 50%, calc(100% - 6px) 50%;
  background-size: 4px 4px, 4px 4px;
  background-repeat: no-repeat;
  padding-right: 22px;
}
.nav-switcher:hover { border-color: var(--cyan); color: var(--text); }
.nav-switcher:focus { outline: 1px solid var(--cyan); outline-offset: 1px; }

/* ── priority badge ──────────────────────────────── */
.priority-badge {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 2px 8px;
  border-radius: 2px;
  white-space: nowrap;
  flex-shrink: 0;
}
.badge-must   { color: var(--must);   border: 1px solid color-mix(in oklch, var(--must)   45%, transparent); background: color-mix(in oklch, var(--must)   12%, transparent); }
.badge-should { color: var(--should); border: 1px solid color-mix(in oklch, var(--should) 45%, transparent); background: color-mix(in oklch, var(--should) 12%, transparent); }
.badge-may    { color: var(--may);    border: 1px solid color-mix(in oklch, var(--may)    45%, transparent); background: color-mix(in oklch, var(--may)    12%, transparent); }
.badge-opt    { color: var(--text3);  border: 1px solid var(--border2); background: transparent; }

/* ── score bar ───────────────────────────────────── */
.score-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 60px;
  justify-content: flex-end;
  flex-shrink: 0;
}
.score-track {
  width: 32px; height: 3px;
  background: var(--border2);
  border-radius: 2px;
  overflow: hidden;
}
.score-fill { height: 100%; border-radius: 2px; }
.score-fill-high   { background: var(--must); }
.score-fill-mid    { background: var(--should); }
.score-fill-low    { background: var(--text3); }
.score-num {
  font-family: var(--mono);
  font-size: 10px;
  min-width: 20px;
  text-align: right;
}
.score-num-high { color: var(--must); }
.score-num-mid  { color: var(--should); }
.score-num-low  { color: var(--text3); }

/* ── toc ─────────────────────────────────────────── */
#toc {
  padding: 0 40px;
  flex: 1;
}
.toc-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
/* title + filters card sits flush on the page: no fill, no border */
.toc-card-head { background: none; border: none; }
.toc-header {
  padding: 13px 20px;
}
/* the filters and the reading list sit in separate cards, gapped like the title↔filters spacing */
#toc .toc-card + .toc-card { margin: 20px 0; }
.toc-body { padding: 8px 20px 16px; }
.toc-group { margin-bottom: 4px; }
.toc-group-head {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0 8px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 4px;
}
.toc-group-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.14em;
  padding: 2px 7px;
  border-radius: 2px;
  white-space: nowrap;
}
.toc-group-count { margin-left: auto; font-family: var(--mono); font-size: 9px; color: var(--text3); }
.info-tip {
  cursor: help;
  font-style: normal;
  font-size: 0.7rem;
  opacity: 0.45;
  position: relative;
  user-select: none;
  line-height: 1;
}
.info-tip:hover { opacity: 1; }
.info-tip::after {
  content: attr(data-tip);
  display: none;
  position: absolute;
  left: 1.4em;
  top: -0.3em;
  width: 22em;
  background: var(--bg-secondary, #1e1e2e);
  color: var(--fg, #cdd6f4);
  border: 1px solid var(--border, #45475a);
  border-radius: 6px;
  padding: 0.5em 0.75em;
  font-size: 0.75rem;
  font-family: inherit;
  line-height: 1.4;
  z-index: 100;
  white-space: normal;
  pointer-events: none;
}
.info-tip:hover::after { display: block; }
/* ── score hover tooltip (rubric dimension breakdown) ── */
.score-tip { position: relative; cursor: help; }
.score-tip::after {
  content: attr(data-tip);
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 0.4em);
  width: max-content;
  max-width: 22em;
  background: var(--bg-secondary, #1e1e2e);
  color: var(--fg, #cdd6f4);
  border: 1px solid var(--border, #45475a);
  border-radius: 6px;
  padding: 0.5em 0.75em;
  font-family: var(--mono);
  font-size: 0.7rem;
  line-height: 1.5;
  z-index: 100;
  white-space: normal;
  pointer-events: none;
}
.score-tip:hover::after { display: block; }
.toc-num {
  font-family: var(--mono);
  font-size: 10px;
  min-width: 20px;
  margin-top: 2px;
  flex-shrink: 0;
}
/* number + category share the first line; the title drops to its own line below */
.toc-row-head { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; }
.toc-row-head .toc-num { margin-top: 0; }
.toc-row-head .toc-cat-label { margin-bottom: 0; }
.toc-num-must   { color: var(--must); }
.toc-num-should { color: var(--should); }
.toc-num-may    { color: var(--may); }
.toc-num-opt    { color: var(--text3); }
.toc-title-link { color: var(--text); font-size: 0.93rem; flex: 1; line-height: 1.5; cursor: pointer; }
.toc-child-indent { color: var(--text3); font-size: 10px; margin-top: 2px; flex-shrink: 0; }
.toc-child-title  { color: var(--text2); font-size: 0.86rem; flex: 1; line-height: 1.5; }
.toc-child-title:hover { color: var(--text); text-decoration: none; }

/* ── toc expandable row ──────────────────────────── */
.toc-row-wrap {
  position: relative;
  /* keep a full 1px border reserved at all times (transparent sides), so opening only
     recolors it — no 1px layout jump from the top/side borders appearing */
  border: 1px solid transparent;
  border-bottom-color: color-mix(in oklch, var(--border) 50%, transparent);
  /* Fluent-style decelerate easing: the card eases out of the list instead of snapping */
  transition: margin 0.25s cubic-bezier(0.1, 0.9, 0.2, 1),
              border-radius 0.25s cubic-bezier(0.1, 0.9, 0.2, 1),
              border-color 0.2s ease,
              box-shadow 0.25s cubic-bezier(0.1, 0.9, 0.2, 1),
              background 0.2s ease;
}
.toc-row-wrap:last-child { border-bottom-color: transparent; }
/* open row "pops out" of the flush list: a self-contained, gapped, elevated panel */
.toc-row-wrap.open {
  margin: 10px 0;
  padding: 14px;
  border-color: var(--border);   /* recolor the already-reserved border; no size change */
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--surface-raised);   /* dedicated elevated surface, lighter than the list card in every theme */
  box-shadow: 0 1px 2px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.10);
}
.toc-row-wrap::before {
  content: "";
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px;
  opacity: 0;
  transition: opacity 0.15s;
}
.toc-row-wrap.must-row::before   { background: var(--must); }
.toc-row-wrap.should-row::before { background: var(--should); }
.toc-row-wrap.may-row::before    { background: var(--may); }
.toc-row-inner {
  display: flex;
  gap: 12px;
  padding: 9px 8px 9px 12px;
  align-items: flex-start;
  cursor: pointer;
  user-select: none;
}
/* plain rows reserve the same left chevron rail as cluster rows (12 + chevron 16
   + gap 12 = 40) so article numbers/titles line up across cluster and plain rows */
.toc-row-wrap > .toc-row-inner { padding-left: 40px; }
.toc-row-meta {
  display: flex;
  gap: 8px;
  margin-top: 3px;
  align-items: center;
  flex-wrap: wrap;
}
.meta-provider {
  margin-left: auto;        /* stick to the right of the meta line */
  flex: 0 0 auto;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.02em;
  color: var(--text3);
}
/* Stretch the header meta row past the title column so the right-stuck
   provider/model lines up with the score bar's right edge:
   flex gap (12px) + fixed score column (60px) = 72px. */
.toc-row-inner .toc-row-meta { width: calc(100% + 72px); }
.toc-row-chevron {
  color: var(--text3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1rem;
  height: 1rem;
  line-height: 1;
  flex-shrink: 0;
  margin-left: 8px;
  align-self: center;
}
.toc-row-chevron svg {
  width: 14px;
  height: 14px;
  display: block;
  overflow: visible;
}
.toc-row-chevron svg path {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.6;
  stroke-linecap: round;
  stroke-linejoin: round;
  transform-origin: 8px 8px;
  /* baseline animation (all browsers): the centered chevron rotates cleanly in place */
  transition: transform 0.28s cubic-bezier(.34, 1.4, .5, 1), stroke 0.15s;
}
.toc-row-wrap:hover .toc-row-chevron { color: var(--text2); }
.toc-row-chevron.open svg path { transform: rotate(180deg); }
/* progressive enhancement: where CSS `d` is supported (Chromium/WebKit), morph the
   chevron's own geometry so it folds from ⌄ to ⌃ instead of spinning */
@supports (d: path("M0 0")) {
  .toc-row-chevron svg path {
    transition: d 0.28s cubic-bezier(.34, 1.4, .5, 1), stroke 0.15s;
  }
  .toc-row-chevron.open svg path {
    transform: none;
    d: path("M4 9.5 L8 5.5 L12 9.5");
  }
}
.toc-row-body { height: 0; overflow: hidden; border-top: 1px solid transparent; }
/* padding-left lifts body content onto the article number/TAGS rail (12 margin +
   28 = 40) while the full-width top divider stays at the 12px inset */
.toc-row-body.open { height: auto; margin: 0 12px; border-top-color: var(--border); margin-bottom: 20px; padding: 9px 0 9px 28px; }
/* smooth Fluent-style height reveal where the browser can animate to auto height
   (Chromium 129+). Elsewhere the body still toggles instantly — no regression. */
@supports (interpolate-size: allow-keywords) {
  :root { interpolate-size: allow-keywords; }
  .toc-row-body, .article-body {
    transition: height 0.26s cubic-bezier(0.1, 0.9, 0.2, 1),
                border-top-color 0.26s cubic-bezier(0.1, 0.9, 0.2, 1);
  }
}
/* expanded content settles in (slide-up + fade), Fluent-style. Lives outside @supports so
   browsers without interpolate-size still animate the content even if the height snaps. */
.toc-row-body.open > *,
.article-body.open > * {
  animation: tocContentIn 0.34s cubic-bezier(0.1, 0.9, 0.2, 1) both;
}
@keyframes tocContentIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
/* light cascade: each successive section starts a touch later */
.toc-row-body.open > :nth-child(2), .article-body.open > :nth-child(2) { animation-delay: 0.04s; }
.toc-row-body.open > :nth-child(3), .article-body.open > :nth-child(3) { animation-delay: 0.08s; }
.toc-row-body.open > :nth-child(n+4), .article-body.open > :nth-child(n+4) { animation-delay: 0.11s; }
@media (prefers-reduced-motion: reduce) {
  .toc-row-body.open > *, .article-body.open > * { animation: none; }
  .toc-row-body, .article-body { transition: none; }
}
/* ── overview ────────────────────────────────────── */
#overview {
  padding: 20px 40px 0;
}
.overview-card {
  container-type: inline-size;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 20px;
  overflow: hidden;
}
.overview-toggle {
  all: unset;
  cursor: pointer;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 24px;
  border-bottom: 1px solid var(--border);
  box-sizing: border-box;
}
.overview-chevron {
  color: var(--text3);
  font-size: 14px;
  transition: transform 0.2s;
}
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.overview-cell {
  padding: 20px 24px;
}
.overview-cell-full { grid-column: 1 / -1; }
.overview-cell-border-r { border-right: 1px solid var(--border); }
.overview-cell-border-b { border-bottom: 1px solid var(--border); }
.overview-cell-head {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 8px;
}
.overview-tag {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.12em;
  padding: 1px 5px;
  border-radius: 2px;
  flex-shrink: 0;
}
.overview-tag-exec {
  color: var(--cyan);
  border: 1px solid color-mix(in oklch, var(--cyan) 35%, transparent);
  background: color-mix(in oklch, var(--cyan) 8%, transparent);
}
.overview-tag-num {
  color: var(--text3);
  border: 1px solid var(--border2);
  background: transparent;
}
.overview-title { font-family: var(--sans); font-weight: 600; font-size: 0.93rem; color: var(--text); letter-spacing: 0.01em; }
.overview-body  { color: var(--text2); font-size: 0.93rem; line-height: 1.75; font-weight: 400; }
.overview-body p { margin-bottom: 0.6rem; }
.overview-body p:last-child { margin-bottom: 0; }
.overview-body ul, .overview-body ol { padding-left: 1.4rem; margin: 0.5rem 0; }
.overview-body li { margin-bottom: 0.25rem; }
.overview-body strong { color: var(--text); }
.overview-body a { color: var(--cyan); }

/* ── filter bar (in toc header) ──────────────────── */
.toc-filters { display: flex; flex-direction: column; gap: 8px; width: 100%; }
.filter-row { display: flex; align-items: flex-start; gap: 12px; }
.filter-label {
  flex-shrink: 0;
  min-width: 64px;
  padding-top: 5px;            /* align label with the first row of pills */
  font-family: var(--mono);
  font-size: 8.5px;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--text3);
}
/* clickable tag pill cloud: filters the reading list by tag */
.toc-tag-cloud { display: flex; flex-wrap: wrap; align-items: center; gap: 5px; flex: 1; }
.tag-pill {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.04em;
  padding: 2px 7px;
  border-radius: 3px;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
  cursor: pointer;
}
.tag-pill:hover { border-color: var(--cyan); color: var(--text); }
.tag-pill.active {
  color: var(--text);
  border-color: var(--cyan);
  background: color-mix(in oklch, var(--cyan) 18%, transparent);
}
.tag-pill.tag-hidden { display: none; }
.tag-show-more { color: var(--cyan); border-color: var(--cyan); }
.tag-show-more:hover { background: color-mix(in oklch, var(--cyan) 10%, transparent); }
.filter-bar { display: flex; flex-wrap: wrap; gap: 2px; }
.filter-btn {
  background: none;
  border: 1px solid transparent;
  border-radius: 2px;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  font-weight: 400;
  color: var(--text3);
  padding: 4px 10px;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.filter-btn.active-all    { color: var(--text2);  background: color-mix(in oklch, var(--text2)  10%, transparent); border-color: color-mix(in oklch, var(--text2)  35%, transparent); font-weight: 600; }
.filter-btn.active-must   { color: var(--must);   background: color-mix(in oklch, var(--must)   10%, transparent); border-color: color-mix(in oklch, var(--must)   35%, transparent); font-weight: 600; }
.filter-btn.active-should { color: var(--should); background: color-mix(in oklch, var(--should) 10%, transparent); border-color: color-mix(in oklch, var(--should) 35%, transparent); font-weight: 600; }
.filter-btn.active-may    { color: var(--may);    background: color-mix(in oklch, var(--may)    10%, transparent); border-color: color-mix(in oklch, var(--may)    35%, transparent); font-weight: 600; }
.cat-btn { text-transform: uppercase; }   /* category values are lowercase; match the priority pills */
/* selected category pill takes that category's color (ALL falls back to cyan) */
.cat-btn[data-cat="research"] { --cat-c: var(--cat-research); }
.cat-btn[data-cat="advisory"] { --cat-c: var(--cat-advisory); }
.cat-btn[data-cat="news"]     { --cat-c: var(--cat-news); }
.cat-btn[data-cat="opinion"]  { --cat-c: var(--cat-opinion); }
.cat-btn[data-cat="guide"]    { --cat-c: var(--cat-guide); }
.cat-btn[data-cat="commercial"]   { --cat-c: var(--cat-commercial); }
.cat-btn[data-cat="sponsored"]    { --cat-c: var(--cat-sponsored); }
.cat-btn[data-cat="announcement"] { --cat-c: var(--cat-announcement); }
.cat-btn.active { color: var(--cat-c, var(--cyan)); background: color-mix(in oklch, var(--cat-c, var(--cyan)) 10%, transparent); border-color: color-mix(in oklch, var(--cat-c, var(--cyan)) 35%, transparent); font-weight: 600; }
.filter-count { opacity: 0.6; }
.source-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
  display: inline-block;
}
.source-name { font-family: var(--mono); font-size: 10px; }
.meta-sep    { color: var(--text3); font-family: var(--mono); font-size: 10px; }
.meta-time   { font-family: var(--mono); font-size: 10px; color: var(--text3); }
/* category header above the title */
.toc-cat-label {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cyan);
}
.toc-cat-label::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 1px;
  background: currentColor;
  flex-shrink: 0;
}
.toc-row-wrap[data-category="research"] .toc-cat-label { color: var(--cat-research); }
.toc-row-wrap[data-category="advisory"] .toc-cat-label { color: var(--cat-advisory); }
.toc-row-wrap[data-category="news"]     .toc-cat-label { color: var(--cat-news); }
.toc-row-wrap[data-category="opinion"]  .toc-cat-label { color: var(--cat-opinion); }
.toc-row-wrap[data-category="guide"]    .toc-cat-label { color: var(--cat-guide); }
.toc-row-wrap[data-category="commercial"]   .toc-cat-label { color: var(--cat-commercial); }
.toc-row-wrap[data-category="sponsored"]    .toc-cat-label { color: var(--cat-sponsored); }
.toc-row-wrap[data-category="announcement"] .toc-cat-label { color: var(--cat-announcement); }
/* cluster members carry their own category color, overriding the canonical's */
.toc-cluster-member[data-category="research"] .toc-cat-label { color: var(--cat-research); }
.toc-cluster-member[data-category="advisory"] .toc-cat-label { color: var(--cat-advisory); }
.toc-cluster-member[data-category="news"]     .toc-cat-label { color: var(--cat-news); }
.toc-cluster-member[data-category="opinion"]  .toc-cat-label { color: var(--cat-opinion); }
.toc-cluster-member[data-category="guide"]    .toc-cat-label { color: var(--cat-guide); }
.toc-cluster-member[data-category="commercial"]   .toc-cat-label { color: var(--cat-commercial); }
.toc-cluster-member[data-category="sponsored"]    .toc-cat-label { color: var(--cat-sponsored); }
.toc-cluster-member[data-category="announcement"] .toc-cat-label { color: var(--cat-announcement); }
/* tags on their own line below the meta line; scrolls horizontally instead of wrapping */
.toc-row-tags {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;       /* Firefox: hide scrollbar */
  -ms-overflow-style: none;    /* legacy Edge/IE: hide scrollbar */
  align-items: center;
  gap: 6px;
  /* separate the tags from the meta line above with a divider */
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid var(--border);
  /* fade the right edge so overflowing tags hint they scroll */
  -webkit-mask-image: linear-gradient(to right, #000 calc(100% - 24px), transparent);
  mask-image: linear-gradient(to right, #000 calc(100% - 24px), transparent);
}
/* hide the right-fade when the tag line is scrolled all the way to the end */
.toc-row-tags.at-end {
  -webkit-mask-image: none;
  mask-image: none;
}
/* on main rows: pull left to align TAGS with the article number (32px = toc-num 20 + gap 12);
   extend right to flush with the block edge (8px = toc-row-inner padding-right); member rows have no number */
.toc-row-inner .toc-row-tags { margin-left: 0; width: calc(100% + 8px); }
.toc-row-tags::-webkit-scrollbar { display: none; } /* WebKit/Blink: hide scrollbar */
.toc-tags-label {
  align-self: center;
  flex-shrink: 0;
  font-family: var(--mono);
  font-size: 8.5px;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--text3);
  margin-right: 2px;
}
.meta-tag {
  flex-shrink: 0;
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.04em;
  padding: 2px 7px;
  border-radius: 3px;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border2);
}
.meta-tag[data-tag] { cursor: pointer; }
.meta-tag[data-tag]:hover { border-color: var(--cyan); color: var(--text); }
.meta-tag.active {
  color: var(--text);
  border-color: var(--cyan);
  background: color-mix(in oklch, var(--cyan) 18%, transparent);
}

/* ── article expanded body ───────────────────────── */
.article-body { height: 0; overflow: hidden; border-top: 1px solid transparent; }
.article-body.open { height: auto; border-top-color: var(--border); }

/* ── WHY justification: collapsed disclosure ─────── */
.why-block {
  margin-top: 1.1rem;          /* sits among the panel sections, below Key Points */
  padding-top: 1.1rem;
  border-top: 1px solid var(--border);
}
.why-label {
  display: inline-flex;        /* compact hit area when collapsed */
  align-items: center;
  gap: 8px;
  cursor: pointer;
  user-select: none;
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: var(--text3);         /* muted, NOT green */
  transition: color .15s;
}
.why-label:hover { color: var(--text2); }
.why-caret {
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  transform: rotate(-90deg);   /* points right when collapsed */
  transition: transform .15s;
}
.why-caret svg { width: 11px; height: 11px; fill: none; stroke: currentColor; stroke-width: 1.6; }
.why-label.open .why-caret { transform: rotate(0deg); }  /* points down */
.why-body {
  display: none;
  margin-top: 0.7rem;
  font-size: 0.96rem;
  line-height: 1.7;
  color: var(--text2);
}
.why-body.open { display: block; }
.why-body p { margin: 0 0 0.55rem; }
.why-body p:last-child { margin: 0; }

.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
}
.tab-btn {
  padding: 0.55rem 1rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text3);
  cursor: pointer;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
  transition: color .15s, border-color .15s;
  margin-bottom: -1px;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--cyan); border-bottom-color: var(--cyan); }
.tab-panel { display: none; padding: 1.25rem 1.4rem; }
.tab-panel.active { display: block; }

/* ── prose ───────────────────────────────────────── */
.prose { line-height: 1.8; color: var(--text2); font-size: 0.96rem; text-align: justify; }
.prose p { margin-bottom: 0.75rem; }
.prose p:last-child { margin-bottom: 0; }
.prose h1, .prose h2, .prose h3 { color: var(--text); font-weight: 600; margin: 1.1rem 0 0.4rem; font-size: 0.9rem; letter-spacing: 0.02em; }
.prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 0.75rem; }
.prose li { margin-bottom: 0.3rem; }
.prose strong { color: var(--text); font-weight: 600; }
.prose em { color: var(--text3); font-style: italic; }
.prose code { background: var(--surface2); border: 1px solid var(--border); border-radius: 3px; padding: 0.1rem 0.35rem; font-family: var(--mono); font-size: 0.86rem; color: var(--text); }
.prose blockquote { border-left: 2px solid color-mix(in oklch, var(--cyan) 30%, transparent); padding-left: 1rem; color: var(--text3); margin: 0.75rem 0; }
.prose a { color: var(--cyan); }

/* matched jargon/entity terms in section text. Inert by default; the highlight + click-to-define
   affordance only appear in Learning mode with the Definitions feature on. */
mark.tag-hl {
  background: transparent;
  color: inherit;
  border-radius: 2px;
  padding: 0 1px;
  position: relative; /* lift above the stretched .report-link::after overlay */
  z-index: 2;
  transition: background .15s;
}
html[data-learning="on"][data-learn-define="on"] mark.tag-hl {
  background: color-mix(in oklch, var(--cyan) 14%, transparent);
  cursor: help;
}
html[data-learning="on"][data-learn-define="on"] mark.tag-hl:hover {
  background: color-mix(in oklch, var(--cyan) 28%, transparent);
  text-decoration: underline dotted color-mix(in oklch, var(--cyan) 55%, transparent);
}
/* Help-level filter: a term shows only when the selected level (1/2/3) >= its tier (data-lvl:
   1=advanced, 2=intermediate, 3=beginner). Revert the highlight for terms above the level. */
html[data-help-level="1"] mark.tag-hl[data-lvl="2"],
html[data-help-level="1"] mark.tag-hl[data-lvl="3"],
html[data-help-level="2"] mark.tag-hl[data-lvl="3"],
html[data-help-level="1"] mark.tag-hl[data-lvl="2"]:hover,
html[data-help-level="1"] mark.tag-hl[data-lvl="3"]:hover,
html[data-help-level="2"] mark.tag-hl[data-lvl="3"]:hover {
  background: transparent;
  cursor: auto;
  text-decoration: none;
}

/* Glossary definition popup */
/* Non-blocking persistent popup pinned bottom-left; never dims or blocks the page. */
.glossary-popup {
  position: fixed;
  left: 1rem;
  bottom: 1rem;
  z-index: 1000;
  max-width: 22rem;
  width: calc(100% - 2rem);
  background: var(--surface, var(--bg));
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: .9rem 1.1rem;
  box-shadow: 0 8px 28px rgba(0,0,0,.4);
  transition: opacity .15s ease, transform .15s ease;
}
.glossary-popup[hidden] { display: none; }
.glossary-popup.is-enter { opacity: 0; transform: translateY(8px); }
.glossary-popup-close {
  position: absolute; top: .4rem; right: .5rem;
  background: none; border: none; color: var(--text2);
  font-size: 1.3rem; line-height: 1; cursor: pointer; padding: .1rem .3rem;
}
.glossary-popup-close:hover { color: var(--text); }
.glossary-popup-term { margin: 0 1.4rem .35rem 0; color: var(--cyan); font-size: 1rem; }
.glossary-popup-type {
  display: inline-block; padding: .05rem .4rem;
  border: 1px solid var(--border); border-radius: 999px;
  font-size: .68rem; letter-spacing: .03em; text-transform: uppercase;
  color: var(--text2);
}
.glossary-popup-type[hidden] { display: none; }
.glossary-popup-def { margin: 0; color: var(--text); line-height: 1.5; font-size: .92rem; }
.glossary-popup-context { margin: .55rem 0 0; color: var(--text2); line-height: 1.45; font-size: .85rem; }
.glossary-popup-context[hidden] { display: none; }
.glossary-popup-context-label {
  display: inline-block; margin-right: .35rem;
  color: var(--cyan); font-weight: 600; font-size: .72rem;
  text-transform: uppercase; letter-spacing: .03em;
}

/* Glossary side panel (right drawer). Available only under Learning mode + the Glossary feature. */
.glossary-panel-toggle, .glossary-panel { display: none; }
html[data-learning="on"][data-learn-glossary="on"] .glossary-panel-toggle { display: block; }
html[data-learning="on"][data-learn-glossary="on"] .glossary-panel { display: flex; }

.glossary-panel-toggle {
  position: fixed;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  z-index: 999;
  writing-mode: vertical-rl;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--should);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-right: none;
  border-radius: 6px 0 0 6px;
  padding: 12px 6px;
  cursor: pointer;
}
.glossary-panel-toggle:hover { border-color: var(--should); color: var(--text); }

.glossary-panel {
  position: fixed;
  top: 0;
  right: 0;
  height: 100vh;
  width: 320px;
  max-width: 100vw;
  z-index: 1001;
  flex-direction: column;
  background: var(--surface, var(--bg));
  border-left: 1px solid var(--border);
  transform: translateX(100%);
  transition: transform .2s ease;
}
.glossary-panel.is-open { transform: none; box-shadow: -8px 0 28px rgba(0,0,0,.35); }
.glossary-panel-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: .9rem 1rem; border-bottom: 1px solid var(--border); flex: none;
}
.glossary-panel-title {
  font-family: var(--mono); font-size: 11px; letter-spacing: .1em;
  text-transform: uppercase; color: var(--should);
}
.glossary-panel-close {
  background: none; border: none; color: var(--text2);
  font-size: 1.4rem; line-height: 1; cursor: pointer; padding: 0 .25rem;
}
.glossary-panel-close:hover { color: var(--text); }
.glossary-panel-search { padding: .75rem 1rem; border-bottom: 1px solid var(--border); flex: none; }
.glossary-panel-search input {
  width: 100%; box-sizing: border-box;
  background: var(--bg); border: 1px solid var(--border2); border-radius: 6px;
  padding: .45rem .6rem; color: var(--text);
  font-family: var(--mono); font-size: .82rem; outline: none;
}
.glossary-panel-search input:focus { border-color: var(--should); }
.glossary-panel-body { flex: 1; overflow-y: auto; padding: .9rem 1rem; }
.glossary-panel-list { margin: 0; padding: 0; }
.glossary-panel-entry[hidden] { display: none; }
/* Help-level filter: hide panel entries whose tier exceeds the selected level (in sync with marks). */
html[data-help-level="1"] .glossary-panel-entry[data-lvl="2"],
html[data-help-level="1"] .glossary-panel-entry[data-lvl="3"],
html[data-help-level="2"] .glossary-panel-entry[data-lvl="3"] { display: none; }
.glossary-panel-empty { margin: 0; color: var(--text2); font-size: .85rem; }
.glossary-panel-term {
  margin: 0; color: var(--text); font-weight: 600; font-size: .92rem;
  display: flex; align-items: center; gap: .4rem; flex-wrap: wrap;
}
.glossary-panel-def {
  margin: .2rem 0 1rem; padding: 0; color: var(--text2);
  font-size: .86rem; line-height: 1.5;
}
.glossary-panel-aliases {
  margin-top: .3rem; color: var(--text2);
  font-size: .8rem; line-height: 1.4; opacity: .85;
}
.glossary-panel-foot { padding: .75rem 1rem; border-top: 1px solid var(--border); flex: none; }
.glossary-panel-suggest {
  display: inline-block; font-size: .8rem; color: var(--cyan); text-decoration: none;
}
.glossary-panel-suggest:hover { text-decoration: underline; }

.kp-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.kp-list li { display: flex; gap: 0.6rem; font-size: 0.96rem; line-height: 1.6; color: var(--text2); }
.kp-list li::before { content: "–"; color: var(--cyan); flex-shrink: 0; font-weight: 600; }
.kp-list li .kp-text { min-width: 0; } /* keep highlighted text inline; don't let <mark> become a flex item */

.report-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
.report-item {
  position: relative;
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: var(--radius);
  padding: 0.75rem 0.85rem;
}
.report-item:hover { border-color: color-mix(in oklch, var(--cyan) 40%, var(--border)); }
.report-title { font-size: 0.96rem; font-weight: 600; line-height: 1.45; color: var(--text); display: flex; align-items: center; gap: 8px; }
.report-link { flex: 1 1 auto; min-width: 0; color: var(--text); }
/* Stretch the title link over the whole card so a click anywhere opens the report. */
.report-link::after { content: ""; position: absolute; inset: 0; z-index: 1; }
.report-item:hover .report-link { color: var(--cyan); }
.report-primary {
  flex-shrink: 0;
  font-family: var(--mono); font-size: 9px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 1px 6px; border-radius: 2px;
  --c: oklch(72% 0.16 150);
  color: var(--c);
  border: 1px solid color-mix(in oklch, var(--c) 45%, transparent);
  background: color-mix(in oklch, var(--c) 12%, transparent);
}
.report-cat {
  flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
  font-family: var(--mono); font-size: 9px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--c);
}
.report-cat::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--c); flex-shrink: 0; }
.report-cat-research { --c: var(--cat-research); }
.report-cat-advisory { --c: var(--cat-advisory); }
.report-cat-news     { --c: var(--cat-news); }
.report-cat-opinion  { --c: var(--cat-opinion); }
.report-cat-guide    { --c: var(--cat-guide); }
.report-cat-commercial   { --c: var(--cat-commercial); }
.report-cat-sponsored    { --c: var(--cat-sponsored); }
.report-cat-announcement { --c: var(--cat-announcement); }
.report-meta { margin-top: 0.25rem; font-family: var(--mono); font-size: 10px; color: var(--text3); letter-spacing: 0.04em; }
.report-context { margin-top: 0.4rem; font-size: 0.89rem; line-height: 1.6; color: var(--text2); }

/* ── structured preview panel (summary / key points / reports) ── */
.panel-section { margin-top: 1.1rem; }
.panel-section:first-child { margin-top: 0; padding-top: 0; border-top: none; }
.panel-subhead {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text3);
  margin-bottom: 0.7rem;
  margin-top: 0.7rem;
}
.panel-subhead::before {
  content: "";
  width: 6px; height: 6px;
  border-radius: 1px;
  background: var(--panel-c, var(--cyan));
  flex-shrink: 0;
}
/* per-section accent (summary / key points / reports) */
.panel-subhead--summary   { --panel-c: var(--cyan); }
.panel-subhead--keypoints { --panel-c: var(--green); }
.panel-subhead--reports   { --panel-c: var(--violet); }
.panel-subhead--plain     { --panel-c: var(--should); }
.panel-subhead--summary,
.panel-subhead--keypoints,
.panel-subhead--reports,
.panel-subhead--plain { color: var(--panel-c); }
/* beginner aids: hidden until Learning mode + the Plain words switch are on (reader consent).
   This gates both the "In plain words" block and the WHY justification disclosure. */
.plain-words-block { display: none; border-top: none; }
html[data-learning="on"][data-learn-plain="on"] .plain-words-block { display: block; }
.plain-label { display: inline-flex; align-items: center; gap: 6px; cursor: pointer; user-select: none; margin-bottom: 0; }
.plain-caret { display: inline-flex; align-items: center; flex: 0 0 auto; transform: rotate(-90deg); transition: transform .15s; }
.plain-caret svg { width: 11px; height: 11px; fill: none; stroke: currentColor; stroke-width: 1.6; }
.plain-label.open .plain-caret { transform: rotate(0deg); }
.plain-body { display: none; margin-top: 0.5rem; }
.plain-body.open { display: block; }
.why-block { display: none; }
html[data-learning="on"][data-learn-plain="on"] .why-block { display: block; }
.summary-switch { display: flex; flex-wrap: wrap; gap: 2px; margin-left: auto; }
.summary-switch .tab-btn {
  margin-bottom: 0;
  padding: 2px 8px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.06em;
  border: 1px solid transparent;
  border-radius: 2px;
}
.summary-switch .tab-btn.active {
  color: var(--cyan);
  border-color: color-mix(in oklch, var(--cyan) 35%, transparent);
  background: color-mix(in oklch, var(--cyan) 8%, transparent);
}
.summary-body .tab-panel { padding: 0; }
.open-source-btn {
  display: inline-block;
  margin-top: 1rem;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--cyan);
  letter-spacing: 0.06em;
  padding: 2px 8px;
  border: 1px solid color-mix(in oklch, var(--cyan) 30%, transparent);
  border-radius: 2px;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}
.open-source-btn:hover { border-color: var(--cyan); text-decoration: none; }
.report-show-more {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.06em;
  padding: 4px 12px;
  border-radius: 3px;
  color: var(--cyan);
  background: var(--surface);
  border: 1px solid color-mix(in oklch, var(--cyan) 35%, transparent);
  cursor: pointer;
  margin-top: 0.5rem;
  display: block;
  width: fit-content;
}
.report-show-more:hover { background: color-mix(in oklch, var(--cyan) 10%, transparent); }
.report-item.report-hidden { display: none; }

/* ── dup cluster in toc ──────────────────────────── */
.toc-cluster { border-bottom: 1px solid color-mix(in oklch, var(--border) 50%, transparent); }
.toc-cluster:last-child { border-bottom: none; }
.toc-cluster summary {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 7px 0; cursor: pointer; list-style: none; user-select: none;
}
.toc-cluster summary::-webkit-details-marker { display: none; }
.toc-cluster summary:hover .toc-title-link { color: var(--text2); }
.toc-cluster-chevron { color: var(--text3); margin-top: 3px; flex-shrink: 0; width: 1rem; height: 1rem; display: inline-flex; align-items: center; justify-content: center; }
.toc-cluster-chevron svg { width: 12px; height: 12px; display: block; overflow: visible; }
.toc-cluster-chevron svg path {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.6;
  stroke-linecap: round;
  stroke-linejoin: round;
  transform-origin: 8px 8px;
  /* baseline (all browsers): the centered chevron rotates cleanly from ▶ to ▼ */
  transition: transform 0.28s cubic-bezier(.34, 1.4, .5, 1);
}
details[open] .toc-cluster-chevron svg path { transform: rotate(90deg); }
/* progressive enhancement: morph the chevron's own geometry instead of spinning */
@supports (d: path("M0 0")) {
  .toc-cluster-chevron svg path { transition: d 0.28s cubic-bezier(.34, 1.4, .5, 1); }
  details[open] .toc-cluster-chevron svg path { transform: none; d: path("M4 6.5 L8 10.5 L12 6.5"); }
}
/* indent so the └ lines up with the canonical row's title:
   row padding-left 12 + chevron 16 + gap 12 + toc-num 20 + gap 12 = 72px */
/* right gutter = canonical row's chevron column (padding-right 8 + chevron 16 +
   margin-left 8 = 32px); keeps member provider/tags aligned with the row above */
.toc-cluster-members { list-style: none; padding-left: 72px; padding-right: 32px; padding-top: 6px; }
.toc-cluster-member {
  display: flex; gap: 8px; align-items: flex-start;
  padding: 8px 0; border-bottom: 1px solid color-mix(in oklch, var(--border) 40%, transparent);
}
.toc-cluster-member:last-child { border-bottom: none; }

/* ── footer ──────────────────────────────────────── */
#footer {
  border-top: 1px solid var(--border);
  padding: 16px 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  /* full-bleed: break out of the 900px body column to span the viewport */
  width: 100vw;
  margin-left: calc(50% - 50vw);
}
.footer-left, .footer-right, .footer-mid {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 0.06em;
}
.footer-mid a { color: var(--text3); text-decoration: underline; text-underline-offset: 2px; }
.footer-mid a:hover { color: var(--cyan); }

/* ── back to top ─────────────────────────────────── */
#back-top {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  background: var(--surface);
  border: 1px solid var(--border2);
  color: var(--text3);
  padding: 0.4rem 0.75rem;
  border-radius: var(--radius);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.06em;
  transition: color .15s, border-color .15s;
}
#back-top:hover { color: var(--cyan); border-color: var(--cyan); text-decoration: none; }

/* the digest title is the header row of the filter card, divided from the filters below */
.toc-title {
  padding: 16px 20px;
  //border-bottom: 1px solid var(--border);
}
.digest-title-text {
  font-family: var(--sans);
  font-size: 1.57rem;
  font-weight: 500;
  color: var(--text);
  line-height: 1.3;
  display: block;
}

/* ── responsive ──────────────────────────────────── */
@media (max-width: 700px) {
  #nav { margin: 0; padding: 10px 16px; height: auto; flex-wrap: wrap; align-items: center; gap: 6px 0; }
  .nav-meta { display: none; }
  .nav-right { display: contents; }
  .nav-swipe { order: 1; margin-left: auto; }
  .nav-count { order: 2; width: 100%; white-space: normal; flex-wrap: wrap; }
  #toc, #overview { padding-left: 16px; padding-right: 16px; }
  #footer { padding: 12px 16px; flex-direction: column; gap: 4px; align-items: flex-start; }
  .overview-grid { grid-template-columns: 1fr; }
  .overview-cell-border-r { border-right: none; border-top: 1px solid var(--border); }
  .overview-cell-full { grid-column: auto; }
  #back-top { bottom: 1rem; right: 0.75rem; }
  .toc-title { padding: 12px 16px; }
  .digest-title-text { font-size: clamp(17px, 5dvw, 1.57rem); }
  /* summary picker: label on its own line, picker wraps full-width beneath it */
  .panel-subhead--summary { flex-wrap: wrap; }
  .panel-subhead--summary .summary-switch {
    margin-left: 0;        /* drop the desktop right-push */
    margin-top: 0.45rem;
    width: 100%;           /* forces the picker onto its own wrapped line */
  }
  /* roomier tap targets on touch screens (text stays the same size) */
  .filter-btn { min-height: 34px; padding: 6px 11px; }
  .summary-switch .tab-btn { min-height: 30px; display: inline-flex; align-items: center; }
  .tag-pill, .meta-tag { padding: 5px 9px; }
  .nav-swipe { padding: 7px 12px; }
  .nav-count { padding: 6px 11px; }
  .nav-theme-select { padding: 7px 24px 7px 10px; }
  /* glossary drawer goes near-full-width on phones */
  .glossary-panel { width: min(92dvw, 360px); }
  /* keep the TAGS filter cloud short on phones; only where a "+N more" button exists
     to reveal the rest (:has scopes it so short clouds never hide unreachable pills) */
  .toc-tag-cloud:has(.tag-show-more):not(.tags-expanded) .tag-pill:nth-of-type(n+13):not(.tag-show-more) { display: none; }
}
@container (min-width: 960px) {
  .overview-grid { grid-template-columns: repeat(3, 1fr); }
}

/* First-visit onboarding tour: a dim overlay whose spotlight cutout frames one nav control while a
   floating card explains it. Only rendered on Learning pages; shown once (downlink.onboarded) and
   replayable from the footer. */
.tour-overlay { position: fixed; inset: 0; z-index: 2000; background: transparent; }
.tour-spotlight {
  position: fixed; z-index: 2001; pointer-events: none;
  top: 0; left: 0; width: 0; height: 0;
  border-radius: 8px;
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.62), 0 0 0 2px var(--should);
  transition: top .25s ease, left .25s ease, width .25s ease, height .25s ease;
}
.tour-spotlight.is-centered { box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.62); }
.tour-card {
  position: fixed; z-index: 2002; box-sizing: border-box;
  width: min(340px, calc(100vw - 28px));
  background: var(--surface); color: var(--text);
  border: 1px solid var(--border2); border-radius: 10px;
  padding: 15px 17px 13px;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
  font-family: var(--sans);
}
.tour-card-step { font-family: var(--mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; }
.tour-card-title { font-size: 15px; font-weight: 600; line-height: 1.25; margin: 0 0 6px; color: var(--text); }
.tour-card-body { font-size: 13px; line-height: 1.5; color: var(--text2); margin: 0; }
.tour-card-foot { display: flex; align-items: center; gap: 8px; margin-top: 14px; }
.tour-dots { display: inline-flex; gap: 5px; align-items: center; margin-right: auto; }
.tour-dots span { width: 6px; height: 6px; border-radius: 50%; background: var(--border2); }
.tour-dots span.is-active { background: var(--should); }
.tour-btn { font-family: var(--mono); font-size: 11px; letter-spacing: .04em; text-transform: uppercase; padding: 5px 11px; border-radius: 4px; border: 1px solid var(--border2); background: transparent; color: var(--text2); cursor: pointer; }
.tour-btn:hover { border-color: var(--should); color: var(--text); }
.tour-btn:focus-visible { outline: 1px solid var(--should); outline-offset: 1px; }
.tour-btn-primary { background: var(--should); border-color: var(--should); color: var(--bg); }
.tour-btn-primary:hover { color: var(--bg); filter: brightness(1.06); }
.tour-skip { border: none; color: var(--text3); padding-left: 2px; }
.tour-skip:hover { border: none; color: var(--text2); }
@media (prefers-reduced-motion: reduce) { .tour-spotlight { transition: none; } }
</style>
</head>
<body>

<!-- Nav -->
<nav id="nav">
  <div class="nav-left">
    <a class="nav-logo" href="index.html">
      <span class="nav-logo-down">DOWN</span><span class="nav-logo-link">LINK</span>
    </a>
    <div class="nav-meta">
      <span class="nav-date">{{.StartedAt}}</span>
      <span class="nav-window">{{.TimeWindow}} window</span>
    </div>
  </div>
  <div class="nav-right">
    <a class="nav-swipe" href="{{.SwipeFilename}}">Triage</a>
    <div class="nav-count">
      <span class="nav-count-dot">■</span>
      <span>{{.ArticleCount}} articles</span>
      {{if .ModelName}}<span style="color:var(--text3)">·</span><span>{{.ModelName}}</span>{{end}}
    </div>
    <select class="nav-theme-select" id="nav-theme-select" onchange="applyTheme(this.value)" title="Select theme" aria-label="Select theme">
      {{range .Themes}}<option value="{{.Value}}">{{.Label}}</option>
      {{end}}</select>
    {{if .HasLearning}}<div class="nav-learn" id="nav-learn">
      <button class="nav-learn-switch" id="nav-learn-switch" type="button" role="switch" aria-checked="false" onclick="toggleLearning()" title="Learning mode: plain-language explanations, the glossary, and click-to-define terms">
        <span class="nav-learn-track"><span class="nav-learn-knob"></span></span>
        <span class="nav-learn-label">Learning</span>
      </button>
      <button class="nav-learn-caret" id="nav-learn-caret" type="button" onclick="toggleLearnMenu()" aria-expanded="false" aria-label="Customize learning">▾</button>
      <span class="nav-help-mini" id="nav-help-mini" aria-hidden="true" title="Current help level" onclick="advanceHelpLevel()">
        <span class="nav-help-mini-dot" data-pos="0"></span>
        <span class="nav-help-mini-dot" data-pos="1"></span>
        <span class="nav-help-mini-dot" data-pos="2"></span>
        <span class="nav-help-flash" id="nav-help-flash" aria-hidden="true"></span>
      </span>
      <div class="learn-card" id="learn-card" role="menu" hidden>
        <div class="learn-card-title">Help level</div>
        <div class="help-slider" id="help-slider" role="slider" tabindex="0"
             aria-label="Help level: novice (most help) to pro (least)"
             aria-valuemin="1" aria-valuemax="3" aria-valuenow="3" aria-valuetext="Novice">
          <span class="help-slider-track" aria-hidden="true"></span>
          <span class="help-slider-dot" data-pos="0" data-level="3" title="Novice — explain every term"></span>
          <span class="help-slider-dot" data-pos="1" data-level="2" title="Standard — security-specific & niche"></span>
          <span class="help-slider-dot" data-pos="2" data-level="1" title="Pro — only niche/advanced"></span>
          <span class="help-slider-knob" id="help-slider-knob" aria-hidden="true"></span>
        </div>
        <div class="help-slider-ends"><span>Novice</span><span>Pro</span></div>
        <div class="learn-card-title">Learning features</div>
        <button class="learn-feature" id="learn-feat-plain" type="button" role="switch" aria-checked="true" onclick="toggleLearnFeature('plain')"><span class="learn-feature-label">Plain words</span><span class="learn-switch"><span class="learn-switch-knob"></span></span></button>
        <button class="learn-feature" id="learn-feat-glossary" type="button" role="switch" aria-checked="true" onclick="toggleLearnFeature('glossary')"><span class="learn-feature-label">Glossary</span><span class="learn-switch"><span class="learn-switch-knob"></span></span></button>
        <button class="learn-feature" id="learn-feat-define" type="button" role="switch" aria-checked="true" onclick="toggleLearnFeature('define')"><span class="learn-feature-label">Definitions</span><span class="learn-switch"><span class="learn-switch-knob"></span></span></button>
      </div>
    </div>{{end}}
  </div>
</nav>

<!-- Reading list / TOC -->
<section id="toc">
  <div class="toc-card toc-card-head">
    {{if .DigestTitle}}<div class="toc-title"><span class="digest-title-text">{{.DigestTitle}}</span></div>{{end}}
    <div class="toc-header" style="display:flex;align-items:center;justify-content:space-between">
      <div class="toc-filters">
        {{if .Categories}}<div class="filter-row">
          <span class="filter-label">CATEGORY</span>
          <div class="filter-bar cat-bar">
            <button class="filter-btn cat-btn active" data-cat="all" onclick="setCategoryFilter(this)">ALL <span class="filter-count">{{.ArticleCount}}</span></button>
            {{range .Categories}}<button class="filter-btn cat-btn" data-cat="{{.}}" onclick="setCategoryFilter(this)">{{.}} <span class="filter-count">{{index $.CategoryCounts .}}</span></button>{{end}}
          </div>
        </div>{{end}}
        <div class="filter-row">
          <span class="filter-label">PRIORITY</span>
          <div class="filter-bar">
            <button class="filter-btn active-all" data-filter="all" onclick="setFilter(this)">ALL <span class="filter-count">{{.ArticleCount}}</span></button>
            <button class="filter-btn" data-filter="must" onclick="setFilter(this)">MUST <span class="filter-count">{{index .PriorityCounts "must"}}</span></button>
            <button class="filter-btn" data-filter="should" onclick="setFilter(this)">SHOULD <span class="filter-count">{{index .PriorityCounts "should"}}</span></button>
            <button class="filter-btn" data-filter="may" onclick="setFilter(this)">MAY <span class="filter-count">{{index .PriorityCounts "may"}}</span></button>
          </div>
        </div>
        {{if .Tags}}<div class="filter-row">
          <span class="filter-label">TAGS</span>
          <div class="toc-tag-cloud">{{if gt (len .Tags) 5}}{{range slice .Tags 0 5}}<button class="tag-pill" data-tag="{{.Name}}" onclick="toggleTag(this.dataset.tag)">{{.Name}} <span class="filter-count">{{.Count}}</span></button>{{end}}{{range slice .Tags 5}}<button class="tag-pill tag-hidden" data-tag="{{.Name}}" onclick="toggleTag(this.dataset.tag)">{{.Name}} <span class="filter-count">{{.Count}}</span></button>{{end}}<button class="tag-pill tag-show-more" onclick="showMoreTags(this)">+{{add (len .Tags) -5}} more</button>{{else}}{{range .Tags}}<button class="tag-pill" data-tag="{{.Name}}" onclick="toggleTag(this.dataset.tag)">{{.Name}} <span class="filter-count">{{.Count}}</span></button>{{end}}{{end}}</div>
        </div>{{end}}
      </div>
    </div>
  </div>
  <div class="toc-card">
    <div class="toc-body">
      {{range .TOCGroups}}<div class="toc-group">
        <div class="toc-group-head">
          <span class="toc-group-label {{tocBadgeClass .Label}}">{{.Label}}</span>{{with tocGroupTooltip .Label}}<span class="info-tip" data-tip="{{.}}">ⓘ</span>{{end}}
          <span class="toc-group-count">{{len .Rows}} items</span>
        </div>
        {{range $i, $row := .Rows}}{{if $row.IsCluster}}<div class="toc-row-wrap {{priorityRowClass $row.Canonical.ReadTag}}" data-priority="{{priorityKey $row.Canonical.ReadTag}}" data-category="{{$row.Canonical.Category}}" data-tags="{{if $row.CanonDetail}}{{joinTags $row.CanonDetail.Tags}}{{end}}">
          <details class="toc-cluster" style="border:none">
            <summary class="toc-row-inner" onclick="handleClusterClick(event,this)">
              <span class="toc-cluster-chevron"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M6.5 4 L10.5 8 L6.5 12"/></svg></span>
              <div style="flex:1;min-width:0">
                <div class="toc-row-head"><span class="toc-num {{tocNumClass $row.Canonical.ReadTag}}">{{printf "%02d" (add $i 1)}}</span>{{if $row.Canonical.Category}}<span class="toc-cat-label">{{$row.Canonical.Category}}</span>{{end}}</div>
                <div style="display:flex;align-items:baseline;gap:7px;flex-wrap:wrap">
                  <span class="toc-title-link">{{$row.Canonical.Title}}</span>
                </div>
                {{if $row.CanonDetail}}<div class="toc-row-meta">
                  <span class="source-dot" style="background:{{paletteVar $row.CanonDetail.Source}}"></span>
                  <span class="source-name" style="color:{{paletteVar $row.CanonDetail.Source}}">{{$row.CanonDetail.Source}}</span>
                  <span class="meta-sep">·</span>
                  <span class="meta-time">{{$row.CanonDetail.PublishedAt}}</span>
                  {{if $row.CanonDetail.HasAnalysis}}<span class="meta-provider">{{$row.CanonDetail.Analysis.ProviderType}} / {{$row.CanonDetail.Analysis.ModelName}}</span>{{end}}
                </div>{{if $row.CanonDetail.Tags}}<div class="toc-row-tags"><span class="toc-tags-label">TAGS</span>{{range $row.CanonDetail.Tags}}<span class="meta-tag" data-tag="{{.}}" onclick="event.stopPropagation();toggleTag(this.dataset.tag)">{{.}}</span>{{end}}</div>{{end}}{{end}}
              </div>
              {{if gt $row.Canonical.ImportanceScore 0}}{{scoreBarTip $row.Canonical.ImportanceScore $row.Canonical.ScoreTip}}{{end}}
              <span class="toc-row-chevron" id="chevron-{{$row.Canonical.Id}}"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.5 L8 10.5 L12 6.5"/></svg></span>
            </summary>
            <ul class="toc-cluster-members">
              {{range $oi, $other := $row.Others}}<li class="toc-cluster-member" data-category="{{$other.Category}}">
                <span class="toc-child-indent">└</span>
                <div style="flex:1;min-width:0">
                  {{if $other.Category}}<div class="toc-cat-label">{{$other.Category}}</div>{{end}}
                  <div class="toc-child-title" onclick="toggleTocMember(this,'member-body-{{$other.Id}}')" style="cursor:pointer">{{$other.Title}}</div>
                  {{with index $row.OtherDetails $oi}}<div class="toc-row-meta">
                    <span class="source-dot" style="background:{{paletteVar .Source}}"></span>
                    <span class="source-name" style="color:{{paletteVar .Source}}">{{.Source}}</span>
                    <span class="meta-sep">·</span>
                    <span class="meta-time">{{.PublishedAt}}</span>
                    {{if .HasAnalysis}}<span class="meta-provider">{{.Analysis.ProviderType}} / {{.Analysis.ModelName}}</span>{{end}}
                  </div>{{if .Tags}}<div class="toc-row-tags"><span class="toc-tags-label">TAGS</span>{{range .Tags}}<span class="meta-tag" data-tag="{{.}}" onclick="event.stopPropagation();toggleTag(this.dataset.tag)">{{.}}</span>{{end}}</div>{{end}}{{end}}
                  {{if index $row.OtherDetails $oi}}<div class="article-body" id="member-body-{{$other.Id}}" data-article-id="{{$other.Id}}">
                    {{$od := index $row.OtherDetails $oi}}
                    {{if $od.HasAnalysis}}
                    {{template "plainWordsBlock" $od.Analysis}}
                    <div class="panel-section">
                      <div class="panel-subhead panel-subhead--summary">Summary
                        <div class="summary-switch">
                          {{if $od.Analysis.Tldr}}<button class="tab-btn active" onclick="switchTab(this,'tldr-{{$other.Id}}')">TL;DR</button>{{end}}
                          <button class="tab-btn{{if not $od.Analysis.Tldr}} active{{end}}" onclick="switchTab(this,'brief-{{$other.Id}}')">Brief</button>
                          {{if $od.Analysis.StandardSynthesis}}<button class="tab-btn" onclick="switchTab(this,'standard-{{$other.Id}}')">Standard</button>{{end}}
                          {{if $od.Analysis.ComprehensiveSynthesis}}<button class="tab-btn" onclick="switchTab(this,'comprehensive-{{$other.Id}}')">Comprehensive</button>{{end}}
                          {{if $od.Analysis.Insights}}<button class="tab-btn" onclick="switchTab(this,'insights-{{$other.Id}}')">Insights</button>{{end}}
                        </div>
                      </div>
                      <div class="summary-body">
                        {{if $od.Analysis.Tldr}}<div id="tldr-{{$other.Id}}" class="tab-panel active"><div class="prose">{{$od.Analysis.Tldr}}</div></div>{{end}}
                        <div id="brief-{{$other.Id}}" class="tab-panel{{if not $od.Analysis.Tldr}} active{{end}}"><div class="prose">{{$od.Analysis.BriefOverview}}</div></div>
                        {{if $od.Analysis.StandardSynthesis}}<div id="standard-{{$other.Id}}" class="tab-panel"><div class="prose">{{$od.Analysis.StandardSynthesis}}</div></div>{{end}}
                        {{if $od.Analysis.ComprehensiveSynthesis}}<div id="comprehensive-{{$other.Id}}" class="tab-panel"><div class="prose">{{$od.Analysis.ComprehensiveSynthesis}}</div></div>{{end}}
                        {{if $od.Analysis.Insights}}<div id="insights-{{$other.Id}}" class="tab-panel"><ul class="kp-list">{{range $od.Analysis.Insights}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
                      </div>
                    </div>
                    {{if $od.Analysis.KeyPoints}}<div class="panel-section"><div class="panel-subhead panel-subhead--keypoints">Key Points</div><ul class="kp-list">{{range $od.Analysis.KeyPoints}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
                    <a href="{{$od.Link}}" target="_blank" rel="noopener" class="open-source-btn">OPEN SOURCE ↗</a>
                    {{if $od.Analysis.Justification}}<div class="why-block"><div class="why-label" onclick="toggleWhy(this)"><span class="why-caret"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.5 L8 10.5 L12 6.5"/></svg></span>JUSTIFICATION</div><div class="why-body">{{$od.Analysis.Justification}}</div></div>{{end}}
                    {{if $od.Analysis.ReferencedReports}}{{template "reportList" $od.Analysis.ReferencedReports}}{{end}}
                    {{else}}<div class="tab-panel active" style="padding:0.5rem 1.4rem">
                      <p style="font-family:var(--mono);font-size:11px;color:var(--must);margin:0 0 0.75rem">⚠ Analysis failed{{if $od.AnalysisError}} — {{$od.AnalysisError}}{{else}} — this article could not be scored or summarized{{end}}.</p>
                      <a href="{{$od.Link}}" target="_blank" rel="noopener" style="font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:0.06em;padding:4px 10px;border:1px solid color-mix(in oklch, var(--cyan) 30%, transparent);border-radius:2px">OPEN SOURCE ↗</a>
                    </div>{{end}}
                  </div>{{end}}
                </div>
              </li>{{end}}
            </ul>
          </details>
          {{if $row.CanonDetail}}<div class="toc-row-body" id="canon-body-{{$row.Canonical.Id}}" data-article-id="{{$row.Canonical.Id}}">
            {{if $row.CanonDetail.HasAnalysis}}
            {{template "plainWordsBlock" $row.CanonDetail.Analysis}}
            <div class="panel-section">
              <div class="panel-subhead panel-subhead--summary">Summary
                <div class="summary-switch">
                  {{if $row.CanonDetail.Analysis.Tldr}}<button class="tab-btn active" onclick="switchTab(this,'tldr-{{$row.Canonical.Id}}')">TL;DR</button>{{end}}
                  <button class="tab-btn{{if not $row.CanonDetail.Analysis.Tldr}} active{{end}}" onclick="switchTab(this,'brief-{{$row.Canonical.Id}}')">Brief</button>
                  {{if $row.CanonDetail.Analysis.StandardSynthesis}}<button class="tab-btn" onclick="switchTab(this,'standard-{{$row.Canonical.Id}}')">Standard</button>{{end}}
                  {{if $row.CanonDetail.Analysis.ComprehensiveSynthesis}}<button class="tab-btn" onclick="switchTab(this,'comprehensive-{{$row.Canonical.Id}}')">Comprehensive</button>{{end}}
                  {{if $row.CanonDetail.Analysis.Insights}}<button class="tab-btn" onclick="switchTab(this,'insights-{{$row.Canonical.Id}}')">Insights</button>{{end}}
                </div>
              </div>
              <div class="summary-body">
                {{if $row.CanonDetail.Analysis.Tldr}}<div id="tldr-{{$row.Canonical.Id}}" class="tab-panel active"><div class="prose">{{$row.CanonDetail.Analysis.Tldr}}</div></div>{{end}}
                <div id="brief-{{$row.Canonical.Id}}" class="tab-panel{{if not $row.CanonDetail.Analysis.Tldr}} active{{end}}"><div class="prose">{{$row.CanonDetail.Analysis.BriefOverview}}</div></div>
                {{if $row.CanonDetail.Analysis.StandardSynthesis}}<div id="standard-{{$row.Canonical.Id}}" class="tab-panel"><div class="prose">{{$row.CanonDetail.Analysis.StandardSynthesis}}</div></div>{{end}}
                {{if $row.CanonDetail.Analysis.ComprehensiveSynthesis}}<div id="comprehensive-{{$row.Canonical.Id}}" class="tab-panel"><div class="prose">{{$row.CanonDetail.Analysis.ComprehensiveSynthesis}}</div></div>{{end}}
                {{if $row.CanonDetail.Analysis.Insights}}<div id="insights-{{$row.Canonical.Id}}" class="tab-panel"><ul class="kp-list">{{range $row.CanonDetail.Analysis.Insights}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
              </div>
            </div>
            {{if $row.CanonDetail.Analysis.KeyPoints}}<div class="panel-section"><div class="panel-subhead panel-subhead--keypoints">Key Points</div><ul class="kp-list">{{range $row.CanonDetail.Analysis.KeyPoints}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
            <a href="{{$row.CanonDetail.Link}}" target="_blank" rel="noopener" class="open-source-btn">OPEN SOURCE ↗</a>
            {{if $row.CanonDetail.Analysis.Justification}}<div class="why-block"><div class="why-label" onclick="toggleWhy(this)"><span class="why-caret"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.5 L8 10.5 L12 6.5"/></svg></span>JUSTIFICATION</div><div class="why-body">{{$row.CanonDetail.Analysis.Justification}}</div></div>{{end}}
            {{if $row.CanonDetail.Analysis.ReferencedReports}}{{template "reportList" $row.CanonDetail.Analysis.ReferencedReports}}{{end}}
            {{else}}<div class="tab-panel active" style="padding:0.5rem 1.4rem">
              <p style="font-family:var(--mono);font-size:11px;color:var(--must);margin:0 0 0.75rem">⚠ Analysis failed{{if $row.CanonDetail.AnalysisError}} — {{$row.CanonDetail.AnalysisError}}{{else}} — this article could not be scored or summarized{{end}}.</p>
              <a href="{{$row.CanonDetail.Link}}" target="_blank" rel="noopener" style="font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:0.06em;padding:4px 10px;border:1px solid color-mix(in oklch, var(--cyan) 30%, transparent);border-radius:2px">OPEN SOURCE ↗</a>
            </div>{{end}}
          </div>{{end}}
        </div>{{else}}<div class="toc-row-wrap {{priorityRowClass $row.Entry.ReadTag}}" data-priority="{{priorityKey $row.Entry.ReadTag}}" data-category="{{$row.Entry.Category}}" data-tags="{{if $row.Detail}}{{joinTags $row.Detail.Tags}}{{end}}">
          <div class="toc-row-inner" onclick="toggleTocRow(this)">
            <div style="flex:1;min-width:0">
              <div class="toc-row-head"><span class="toc-num {{tocNumClass $row.Entry.ReadTag}}">{{printf "%02d" (add $i 1)}}</span>{{if $row.Entry.Category}}<span class="toc-cat-label">{{$row.Entry.Category}}</span>{{end}}</div>
              <div style="display:flex;align-items:baseline;gap:7px;flex-wrap:wrap">
                <span class="toc-title-link">{{$row.Entry.Title}}</span>
              </div>
              {{if $row.Detail}}<div class="toc-row-meta">
                <span class="source-dot" style="background:{{paletteVar $row.Detail.Source}}"></span>
                <span class="source-name" style="color:{{paletteVar $row.Detail.Source}}">{{$row.Detail.Source}}</span>
                <span class="meta-sep">·</span>
                <span class="meta-time">{{$row.Detail.PublishedAt}}</span>
                {{if $row.Detail.HasAnalysis}}<span class="meta-provider">{{$row.Detail.Analysis.ProviderType}} / {{$row.Detail.Analysis.ModelName}}</span>{{end}}
              </div>{{if $row.Detail.Tags}}<div class="toc-row-tags"><span class="toc-tags-label">TAGS</span>{{range $row.Detail.Tags}}<span class="meta-tag" data-tag="{{.}}" onclick="event.stopPropagation();toggleTag(this.dataset.tag)">{{.}}</span>{{end}}</div>{{end}}{{end}}
            </div>
            {{if gt $row.Entry.ImportanceScore 0}}{{scoreBarTip $row.Entry.ImportanceScore $row.Entry.ScoreTip}}{{end}}
            <span class="toc-row-chevron"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.5 L8 10.5 L12 6.5"/></svg></span>
          </div>
          {{if $row.Detail}}<div class="toc-row-body" data-article-id="{{$row.Entry.Id}}">
            {{if $row.Detail.HasAnalysis}}
            {{template "plainWordsBlock" $row.Detail.Analysis}}
            <div class="panel-section">
              <div class="panel-subhead panel-subhead--summary">Summary
                <div class="summary-switch">
                  {{if $row.Detail.Analysis.Tldr}}<button class="tab-btn active" onclick="switchTab(this,'tldr-{{$row.Entry.Id}}')">TL;DR</button>{{end}}
                  <button class="tab-btn{{if not $row.Detail.Analysis.Tldr}} active{{end}}" onclick="switchTab(this,'brief-{{$row.Entry.Id}}')">Brief</button>
                  {{if $row.Detail.Analysis.StandardSynthesis}}<button class="tab-btn" onclick="switchTab(this,'standard-{{$row.Entry.Id}}')">Standard</button>{{end}}
                  {{if $row.Detail.Analysis.ComprehensiveSynthesis}}<button class="tab-btn" onclick="switchTab(this,'comprehensive-{{$row.Entry.Id}}')">Comprehensive</button>{{end}}
                  {{if $row.Detail.Analysis.Insights}}<button class="tab-btn" onclick="switchTab(this,'insights-{{$row.Entry.Id}}')">Insights</button>{{end}}
                </div>
              </div>
              <div class="summary-body">
                {{if $row.Detail.Analysis.Tldr}}<div id="tldr-{{$row.Entry.Id}}" class="tab-panel active"><div class="prose">{{$row.Detail.Analysis.Tldr}}</div></div>{{end}}
                <div id="brief-{{$row.Entry.Id}}" class="tab-panel{{if not $row.Detail.Analysis.Tldr}} active{{end}}"><div class="prose">{{$row.Detail.Analysis.BriefOverview}}</div></div>
                {{if $row.Detail.Analysis.StandardSynthesis}}<div id="standard-{{$row.Entry.Id}}" class="tab-panel"><div class="prose">{{$row.Detail.Analysis.StandardSynthesis}}</div></div>{{end}}
                {{if $row.Detail.Analysis.ComprehensiveSynthesis}}<div id="comprehensive-{{$row.Entry.Id}}" class="tab-panel"><div class="prose">{{$row.Detail.Analysis.ComprehensiveSynthesis}}</div></div>{{end}}
                {{if $row.Detail.Analysis.Insights}}<div id="insights-{{$row.Entry.Id}}" class="tab-panel"><ul class="kp-list">{{range $row.Detail.Analysis.Insights}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
              </div>
            </div>
            {{if $row.Detail.Analysis.KeyPoints}}<div class="panel-section"><div class="panel-subhead panel-subhead--keypoints">Key Points</div><ul class="kp-list">{{range $row.Detail.Analysis.KeyPoints}}<li><span class="kp-text">{{.}}</span></li>{{end}}</ul></div>{{end}}
            <a href="{{$row.Detail.Link}}" target="_blank" rel="noopener" class="open-source-btn">OPEN SOURCE ↗</a>
            {{if $row.Detail.Analysis.Justification}}<div class="why-block"><div class="why-label" onclick="toggleWhy(this)"><span class="why-caret"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.5 L8 10.5 L12 6.5"/></svg></span>JUSTIFICATION</div><div class="why-body">{{$row.Detail.Analysis.Justification}}</div></div>{{end}}
            {{if $row.Detail.Analysis.ReferencedReports}}{{template "reportList" $row.Detail.Analysis.ReferencedReports}}{{end}}
            {{else}}<div class="tab-panel active" style="padding:1.25rem 1.4rem">
              <p style="font-family:var(--mono);font-size:11px;color:var(--must);margin:0 0 0.75rem">⚠ Analysis failed{{if $row.Detail.AnalysisError}} — {{$row.Detail.AnalysisError}}{{else}} — this article could not be scored or summarized{{end}}.</p>
              <a href="{{$row.Detail.Link}}" target="_blank" rel="noopener" style="font-family:var(--mono);font-size:10px;color:var(--cyan);letter-spacing:0.06em;padding:4px 10px;border:1px solid color-mix(in oklch, var(--cyan) 30%, transparent);border-radius:2px">OPEN SOURCE ↗</a>
            </div>{{end}}
          </div>{{end}}
        </div>{{end}}{{end}}
      </div>{{end}}
    </div>
  </div>
</section>

<!-- Intelligence Brief / Overview -->
{{if .OverviewSections}}<section id="overview">
  <div class="overview-card">
    <button class="overview-toggle" onclick="toggleOverview(this)">
      <span class="section-label">INTELLIGENCE BRIEF</span>
      <span class="overview-chevron" style="transform:rotate(180deg)">⌄</span>
    </button>
    <div class="overview-grid" id="overview-grid">
