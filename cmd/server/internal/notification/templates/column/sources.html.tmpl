<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
<meta charset="UTF-8">
<script>
// Set the theme before first paint to avoid a flash. A saved choice wins;
// otherwise the server-rendered data-theme (the configured default) is kept.
// Shared key across digest/archive/swipe/sources pages.
(function(){
  try {
    var valid = { {{range .Themes}}"{{.Value}}": 1, {{end}} };
    var t = localStorage.getItem('downlink.theme');
    if (valid[t]) document.documentElement.dataset.theme = t;
  } catch(e){}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<meta name="description" content="DOWNLINK · the feeds this archive is built from">
<meta property="og:type" content="website">
<meta property="og:title" content="DOWNLINK // sources">
<meta property="og:description" content="The feeds aggregated into the DOWNLINK news digests.">
<title>DOWNLINK // sources</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Sans+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
@view-transition { navigation: auto; }
@keyframes vt-slide-fade-out {
  to { opacity: 0; transform: translateX(24px); }
}
@keyframes vt-slide-fade-in {
  from { opacity: 0; transform: translateX(-24px); }
}
@media (prefers-reduced-motion: no-preference) {
  ::view-transition-old(root) {
    animation: vt-slide-fade-out 220ms cubic-bezier(0.4, 0, 1, 1) both;
  }
  ::view-transition-new(root) {
    animation: vt-slide-fade-in 320ms cubic-bezier(0, 0, 0.2, 1) 120ms both;
  }
}
:root {
  color-scheme: dark;
  --bg: #0a0d10;
  --bg-2: #0e1216;
  --panel: #11161b;
  --panel-2: #161c22;
  --line: #1e262e;
  --line-2: #2a343d;
  --ink: #d8e2ea;
  --ink-dim: #8a98a5;
  --ink-faint: #5a6772;
  --accent: #6ad1c4;
  --accent-2: #f0c674;
  --must: #f06b6b;
  --should: #f0c674;
  --may: #6ad1c4;
  --opt: #8a98a5;
  --grid-dot: rgba(255,255,255,.045);
  --halo: rgba(106,209,196,.18);
}
html[data-theme="contrast"] {
  color-scheme: dark;
  --bg: #000;
  --bg-2: #050505;
  --panel: #0a0a0a;
  --panel-2: #111;
  --line: #2a2a2a;
  --line-2: #3a3a3a;
  --ink: #fff;
  --ink-dim: #c7c7c7;
  --ink-faint: #888;
  --accent: #00ffd1;
  --accent-2: #ffd24a;
  --must: #ff5050;
  --should: #ffd24a;
  --may: #00ffd1;
  --opt: #aaa;
  --grid-dot: rgba(255,255,255,.08);
  --halo: rgba(0,255,209,.25);
}
html[data-theme="mono"] {
  color-scheme: dark;
  --bg: #0c0c0c;
  --bg-2: #101010;
  --panel: #131313;
  --panel-2: #181818;
  --line: #242424;
  --line-2: #333;
  --ink: #e6e6e6;
  --ink-dim: #9a9a9a;
  --ink-faint: #5e5e5e;
  --accent: #e6e6e6;
  --accent-2: #bdbdbd;
  --must: #f0f0f0;
  --should: #c8c8c8;
  --may: #9a9a9a;
  --opt: #6a6a6a;
  --grid-dot: rgba(255,255,255,.04);
  --halo: rgba(255,255,255,.08);
}
html[data-theme="light"] {
  color-scheme: light;
  --bg:        #efeeea;
  --bg-2:      #e8e7e2;
  --panel:     #fafaf8;
  --panel-2:   #f0efeb;
  --line:      #d3d2cc;
  --line-2:    #b8b7b0;
  --ink:       #0d0c0a;
  --ink-dim:   #273f4f;
  --ink-faint: #5c6e78;
  --accent:    oklch(58% 0.13 45);
  --accent-2:  oklch(58% 0.13 78);
  --must:      oklch(58% 0.13 25);
  --should:    oklch(58% 0.13 67);
  --may:       oklch(58% 0.13 250);
  --opt:       #5c6e78;
  --grid-dot:  rgba(0,0,0,.035);
  --halo:      rgba(254,119,67,.15);
}
html[data-theme="colorblind"] {
  color-scheme: light;
  --bg:        #efeeea;
  --bg-2:      #e8e7e2;
  --panel:     #fafaf8;
  --panel-2:   #f0efeb;
  --line:      #d3d2cc;
  --line-2:    #b8b7b0;
  --ink:       #0d0c0a;
  --ink-dim:   #273f4f;
  --ink-faint: #5c6e78;
  --accent:    #0072b2;
  --accent-2:  #8a6d00;
  --must:      #c44601;
  --should:    #8a6d00;
  --may:       #2f79a5;
  --opt:       #5c6e78;
  --grid-dot:  rgba(0,0,0,.035);
  --halo:      rgba(0,114,178,.15);
}
html[data-theme="pastel"] {
  color-scheme: light;
  --bg:        #faf6e6;
  --bg-2:      #f1ead2;
  --panel:     #fffdf4;
  --panel-2:   #f5efda;
  --line:      #e6dcbf;
  --line-2:    #d2c5a2;
  --ink:       #3a3137;
  --ink-dim:   #6c5560;
  --ink-faint: #9c8a86;
  --accent:    #1f9d8f;
  --accent-2:  #e08a2e;
  --must:      #d9534f;
  --should:    #e08a2e;
  --may:       #4a90d9;
  --opt:       #9c8a86;
  --grid-dot:  rgba(0,0,0,.03);
  --halo:      rgba(31,157,143,.15);
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; overflow-x: hidden; }
body {
  min-height: 100vh;
  background: var(--bg);
  background-image: radial-gradient(circle at 1px 1px, var(--grid-dot) 1px, transparent 0);
  background-attachment: fixed;
  background-size: 18px 18px;
  color: var(--ink);
  font: clamp(15px, 1dvw, 20px)/1.5 "IBM Plex Sans", system-ui, sans-serif;
}
::selection { background: var(--accent); color: #001210; }
a { color: inherit; text-decoration: none; }
button, input, select { font: inherit; color: inherit; }
.mono { font-family: "IBM Plex Mono", ui-monospace, monospace; }
#app { max-width: 1280px; margin: 0 auto; padding: 28px 28px 96px; }
.topbar {
  display: flex;
  align-items: center;
  gap: 16px;
  border-bottom: 1px solid var(--line);
  margin-bottom: 22px;
  padding-bottom: 14px;
}
.brand { display: flex; align-items: baseline; gap: 10px; letter-spacing: .08em; text-decoration: none; color: inherit; }
.brand .pulse {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 0 var(--halo);
  animation: pulse 2.4s infinite;
}
.brand .word {
  font-family: "IBM Plex Sans Condensed", "IBM Plex Sans", sans-serif;
  font-size: 1.57rem;
  font-weight: 700;
}
.brand .slash { color: var(--ink-faint); }
.brand .sub {
  color: var(--ink-dim);
  font: 11px "IBM Plex Mono", ui-monospace, monospace;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.topbar .spacer { flex: 1; }
.topbar-theme-select {
  font: 12px "IBM Plex Mono", ui-monospace, monospace;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--ink-dim);
  border: 1px solid var(--line-2);
  background: var(--panel);
  padding: 4px 28px 4px 9px;
  border-radius: 2px;
  cursor: pointer;
  line-height: 1;
  appearance: none;
  -webkit-appearance: none;
  background-image: linear-gradient(45deg, transparent 50%, var(--ink-faint) 50%),
                    linear-gradient(135deg, var(--ink-faint) 50%, transparent 50%);
  background-position: calc(100% - 10px) 50%, calc(100% - 6px) 50%;
  background-size: 4px 4px, 4px 4px;
  background-repeat: no-repeat;
}
.topbar-theme-select:hover { border-color: var(--accent); color: var(--ink); }
.topbar-theme-select:focus-visible { outline: 1px solid var(--accent); outline-offset: 1px; }
.meta {
  color: var(--ink-dim);
  font: 11px "IBM Plex Mono", ui-monospace, monospace;
  letter-spacing: .06em;
}
.meta b { color: var(--ink); font-weight: 500; }
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 var(--halo); }
  70% { box-shadow: 0 0 0 10px rgba(0,0,0,0); }
  100% { box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
.page-head { margin: 4px 0 24px; }
.page-head h1 {
  font-family: "IBM Plex Sans Condensed", "IBM Plex Sans", sans-serif;
  font-size: 1.71rem;
  font-weight: 700;
  letter-spacing: .02em;
  margin: 0 0 6px;
}
.page-head p { margin: 0; color: var(--ink-dim); font-size: 13px; max-width: 60ch; }
.removal-btn {
  display: inline-block;
  margin-top: 14px;
  border: 1px solid var(--line-2);
  background: var(--panel);
  color: var(--ink-dim);
  font: 11px "IBM Plex Mono", ui-monospace, monospace;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 7px 12px;
  border-radius: 2px;
  transition: border-color .15s ease, color .15s ease;
}
.removal-btn:hover { border-color: var(--accent); color: var(--accent); }
.sources {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 12px;
}
.src {
  position: relative;
  border: 1px solid var(--line);
  background: linear-gradient(180deg, var(--panel-2), var(--panel));
  padding: 14px 16px;
  transition: border-color .15s ease, transform .15s ease;
}
.src:hover { border-color: var(--accent); transform: translateY(-1px); }
.src .title {
  display: block;
  font-weight: 600;
  font-size: 14px;
  color: var(--ink);
  margin-bottom: 4px;
}
.src .title::after { content: ""; position: absolute; inset: 0; }
.src:hover .title { color: var(--accent); }
.src .host {
  font: 11px "IBM Plex Mono", ui-monospace, monospace;
  color: var(--ink-faint);
  letter-spacing: .04em;
  word-break: break-all;
}
.empty {
  border: 1px dashed var(--line);
  background: var(--panel);
  color: var(--ink-faint);
  font: 12px "IBM Plex Mono", ui-monospace, monospace;
  padding: 60px 20px;
  text-align: center;
}
.foot {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 8px;
  border-top: 1px solid var(--line);
  color: var(--ink-faint);
  font: 11px "IBM Plex Mono", ui-monospace, monospace;
  letter-spacing: .06em;
  margin-top: 36px;
  padding-top: 16px;
}
.foot a:hover { color: var(--accent); }
</style>
</head>
<body>
<main id="app">
  <div class="topbar">
    <a class="brand" href="index.html">
      <span class="pulse"></span>
      <span class="word">DOWNLINK</span>
      <span class="slash">//</span>
      <span class="sub">sources</span>
    </a>
    <div class="spacer"></div>
    <div class="meta"><b>{{len .Sources}}</b> feeds</div>
    <select class="topbar-theme-select" id="theme" title="Select theme" aria-label="Select theme">
      {{range .Themes}}<option value="{{.Value}}">{{.Label}}</option>
      {{end}}
    </select>
  </div>

  <header class="page-head">
    <h1>Sources</h1>
    <p>The feeds aggregated into the DOWNLINK news digests.</p>
    <a class="removal-btn" href="https://github.com/ma111e/downlink/issues/new?template=site-exclusion.yml" target="_blank" rel="noopener noreferrer">Are you a source? Opt out</a>
  </header>

  {{if .Sources}}
  <ul class="sources">
    {{range .Sources}}
    <li class="src">
      <a class="title" href="{{.URL}}" target="_blank" rel="noopener noreferrer">{{.Title}}</a>
      <span class="host">{{.Host}}</span>
    </li>
    {{end}}
  </ul>
  {{else}}
  <div class="empty">No sources configured.</div>
  {{end}}

  <footer class="foot">
    <span>DOWNLINK · sources · {{.Commit}}</span>
    <span>{{len .Sources}} source{{if ne (len .Sources) 1}}s{{end}}</span>
    <span><a href="index.html">&larr; back to archive</a></span>
  </footer>
</main>
<script>
(function() {
  var THEME_KEY = 'downlink.theme';
  var sel = document.getElementById('theme');
  if (!sel) return;
  var current = localStorage.getItem(THEME_KEY) || document.documentElement.dataset.theme || 'dark';
  document.documentElement.dataset.theme = current;
  sel.value = current;
  sel.addEventListener('change', function() {
    document.documentElement.dataset.theme = sel.value;
    localStorage.setItem(THEME_KEY, sel.value);
  });
})();
</script>
</body>
</html>
