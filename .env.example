# DOWNLINK server configuration
# Copy this file to .env and adjust values as needed.
# CLI flags always take precedence over environment variables.

# --- General Server Settings ---
DOWNLINK_HOST=localhost
DOWNLINK_PORT=50051
DOWNLINK_TLS=false
DOWNLINK_CERT_FILE=
DOWNLINK_KEY_FILE=

# Refresh all feeds on startup
DOWNLINK_REFRESH=false

# Log level: trace, debug, info, warn, error
DOWNLINK_LOG_LEVEL=info

# --- Docker Auto-Start ---
# Automatically start Lightpanda / Solimen containers without prompting
DOWNLINK_AUTO_START_LIGHTPANDA=false
DOWNLINK_AUTO_START_SOLIMEN=false

# Solimen service address for full_browser scraping
DOWNLINK_SOLIMEN_ADDR=http://localhost:5011

# --- LLM Analysis ---
# Maximum number of concurrent LLM analysis requests
DOWNLINK_MAX_CONCURRENT_LLM_REQUESTS=1

# --- GitHub Pages Publishing ---
# Enable/disable GitHub Pages publishing (overrides config.json)
DOWNLINK_GH_PAGES_ENABLED=false

# GitHub Pages repo URL
DOWNLINK_GH_PAGES_REPO=https://github.com/user/repo.git

# Branch to push to
DOWNLINK_GH_PAGES_BRANCH=main

# Configure Pages source at '/' before publishing
DOWNLINK_GH_PAGES_CONFIGURE=false

# GitHub PAT with contents:write scope
DOWNLINK_GH_PAGES_TOKEN=

# Subdirectory inside the repo for digest files
DOWNLINK_GH_PAGES_OUTPUT_DIR=

# Public base URL of the Pages site
DOWNLINK_GH_PAGES_BASE_URL=https://user.github.io

# Commit author name and email
DOWNLINK_GH_PAGES_COMMIT_AUTHOR=
DOWNLINK_GH_PAGES_COMMIT_EMAIL=

# Local working clone directory
DOWNLINK_GH_PAGES_CLONE_DIR=

# Discord webhook URL to notify when a page is published
DOWNLINK_GH_PAGES_DISCORD_WEBHOOK=
