# Runtime overrides loaded automatically from .env by both the server and dlk.
# Every server flag has a DOWNLINK_* equivalent; these override config.json and are
# themselves overridden by an explicit CLI flag. See docs/configuration.md.

# --- Server ---
DOWNLINK_HOST=localhost
DOWNLINK_PORT=50051
DOWNLINK_TLS=false
DOWNLINK_CERT_FILE=
DOWNLINK_KEY_FILE=
DOWNLINK_REFRESH=false
DOWNLINK_ADMIN_PORT=65262
DOWNLINK_PROFILES_FILE=profiles.yml
DOWNLINK_LAYOUTS_DIR=layouts

# --- Logging / tracing ---
DOWNLINK_LOG_LEVEL=info
# Set DOWNLINK_LOG_LEVEL=trace to dump raw LLM prompt/response chains and feed/scrape
# content to disk. DOWNLINK_TRACE_DIR overrides the location (default: /tmp/downlink-trace-<timestamp>).
DOWNLINK_TRACE_DIR=
DOWNLINK_LLM_MONITOR_RETENTION=100
DOWNLINK_FEED_MONITOR_RETENTION=100

# --- Scraping ---
DOWNLINK_AUTO_START_LIGHTPANDA=false
DOWNLINK_AUTO_START_SOLIMEN=false
DOWNLINK_SOLIMEN_ADDR=http://localhost:5011

# --- Analysis ---
DOWNLINK_MAX_CONCURRENT_LLM_REQUESTS=1
DOWNLINK_AUTO_ANALYZE=false
DOWNLINK_VIBE_SCORE=false
DOWNLINK_GLOSSARY=false

# --- GitHub Pages publishing ---
DOWNLINK_GH_PAGES_ENABLED=false
DOWNLINK_GH_PAGES_REPO=https://github.com/user/repo.git
DOWNLINK_GH_PAGES_BRANCH=main
DOWNLINK_GH_PAGES_CONFIGURE=false
DOWNLINK_GH_PAGES_TOKEN=
DOWNLINK_GH_PAGES_OUTPUT_DIR=
DOWNLINK_GH_PAGES_BASE_URL=https://user.github.io
DOWNLINK_GH_PAGES_COMMIT_AUTHOR=
DOWNLINK_GH_PAGES_COMMIT_EMAIL=
DOWNLINK_GH_PAGES_CLONE_DIR=
DOWNLINK_GH_PAGES_DISCORD_WEBHOOK=
DOWNLINK_GH_PAGES_WINDOW_DAYS=0

# --- Advanced / rarely needed ---
# Used by `dlk publish` only; maps to github_pages.layout (empty = "default").
#DOWNLINK_GH_PAGES_THEME=
# OAuth endpoint overrides for testing or alternative deployments. Leave unset for
# normal use; defaults target the official OpenAI/Anthropic endpoints.
#DOWNLINK_CODEX_ISSUER=
#DOWNLINK_CODEX_CLIENT_ID=
#DOWNLINK_CODEX_BASE_URL=
#DOWNLINK_CLAUDE_CLIENT_ID=
#DOWNLINK_CLAUDE_AUTHORIZE_URL=
#DOWNLINK_CLAUDE_TOKEN_URL=
#DOWNLINK_CLAUDE_REDIRECT_URI=
#DOWNLINK_CLAUDE_SCOPES=
#DOWNLINK_CLAUDE_BASE_URL=
